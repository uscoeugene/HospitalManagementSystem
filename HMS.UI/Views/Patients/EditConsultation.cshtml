@model HMS.UI.Models.CreateConsultationViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
}

<div class="portal-card">
    <div class="portal-card-header">Edit Consultation</div>
    <div class="portal-card-body">
        <partial name="_PatientHeader" model="ViewBag.Patient" />
        <hr />
        <form asp-action="EditConsultation" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="PatientId" />
            <input type="hidden" asp-for="VisitId" />

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Date</label>
                    <input asp-for="ConsultationAt" type="datetime-local" class="form-control" value="@Model.ConsultationAt.ToLocalTime().ToString("yyyy-MM-ddTHH:mm")" />
                </div>
                <div class="col-md-8">
                    <label class="form-label">Provider</label>
                    @{
                        var providers = ViewBag.Providers as IEnumerable<HMS.UI.Models.Profile.ProviderViewModel> ?? Enumerable.Empty<HMS.UI.Models.Profile.ProviderViewModel>();
                        var selected = providers.FirstOrDefault(x => Model.DoctorId.HasValue && x.UserId == Model.DoctorId.Value);
                    }
                    @if (selected != null)
                    {
                        <div class="d-flex align-items-center gap-2 mb-2">
                            @if (!string.IsNullOrWhiteSpace(selected.PhotoUrl)) { <img src="@selected.PhotoUrl" class="rounded-circle" style="width:40px;height:40px;object-fit:cover;" /> }
                            <div>
                                <div class="fw-semibold">@selected.FullName</div>
                                <div class="small text-muted">@selected.JobTitle</div>
                            </div>
                        </div>
                    }
                    <select asp-for="DoctorId" class="form-select">
                        <option value="">Select provider</option>
                        @foreach(var p in providers)
                        {
                            var sel = (Model.DoctorId.HasValue && Model.DoctorId.Value == p.UserId) ? "selected" : "";
                            @:<option value="@p.UserId" @sel>@p.FullName (@p.JobTitle)</option>
                        }
                    </select>
                </div>
                <div class="col-12">
                    <label class="form-label">Chief Complaint</label>
                    <input asp-for="ChiefComplaint" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">History of Present Illness</label>
                    <textarea asp-for="HistoryOfPresentIllness" class="form-control"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Physical Examination</label>
                    <textarea asp-for="PhysicalExamination" class="form-control"></textarea>
                </div>
                <div class="col-6">
                    <label class="form-label">Diagnosis Codes</label>
                    <input asp-for="DiagnosisCodes" class="form-control" />
                </div>
                <div class="col-6">
                    <label class="form-label">Procedures</label>
                    <input asp-for="Procedures" class="form-control" />
                </div>
                <div class="col-12">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control"></textarea>
                </div>
                <div class="col-12">
                    <label class="form-label">Status</label>
                    <select asp-for="Status" class="form-select">
                        <option>Pending</option>
                        <option>Completed</option>
                        <option>Cancelled</option>
                    </select>
                </div>
            </div>

            <div class="mt-3">
                <button class="btn btn-primary">Save</button>
                <a asp-action="VisitDetails" asp-route-id="@Model.VisitId" class="btn btn-light">Cancel</a>
            </div>
        </form>
    </div>
</div>
