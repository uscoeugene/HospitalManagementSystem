@model HMS.UI.Models.VisitDetailsViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Visit Details";
}

<div class="page-content">

    <!-- Patient & Visit Header -->
    <div class="portal-card shadow-soft mb-4">
        <div class="portal-card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center">
            <div class="mb-3 mb-md-0">
                <partial name="_PatientHeader" model="Model.Patient" />
            </div>

@* hidden antiforgery token to clone into modal forms *@
<div id="af-token" style="display:none">@Html.AntiForgeryToken()</div>

@* Invoice modal (populated by JS) *@
<div class="modal fade" id="invoiceModal" tabindex="-1" aria-labelledby="invoiceModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="invoiceModalLabel">Invoice</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body" id="invoiceModalBody">
        <div class="text-center text-muted">Loading...</div>
      </div>
      <div class="modal-footer" id="invoiceModalFooter">
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function(){
    // If server set TempData["ShowInvoiceId"], render modal for that invoice
    var showId = '@(TempData["ShowInvoiceId"] ?? "")';
    if(showId){
        try{
            var id = showId;
            fetch('/billing/' + id)
            .then(function(res){ if(!res.ok) throw new Error('Failed to load invoice'); return res.json(); })
            .then(function(inv){
                var body = document.getElementById('invoiceModalBody');
                var footer = document.getElementById('invoiceModalFooter');
                body.innerHTML = '';
                var html = '';
                html += '<div><strong>Invoice:</strong> ' + (inv.invoiceNumber || '') + '</div>';
                html += '<div class="mb-2"><strong>Status:</strong> ' + (inv.status || '') + '</div>';
                html += '<div class="mb-2"><strong>Total:</strong> ' + (inv.totalAmount || 0) + ' ' + (inv.currency||'') + '</div>';
                html += '<div class="mb-2"><strong>Paid:</strong> ' + (inv.amountPaid || 0) + '</div>';
                html += '<h6 class="mt-3">Items</h6>';
                html += '<table class="table"><thead><tr><th>Description</th><th>Unit</th><th>Qty</th><th>Line</th></tr></thead><tbody>';
                (inv.items||[]).forEach(function(it){ html += '<tr><td>'+ (it.description||'') +'</td><td>'+ (it.unitPrice||'') +'</td><td>'+ (it.quantity||'') +'</td><td>'+ (it.lineTotal||'') +'</td></tr>'; });
                html += '</tbody></table>';
                body.innerHTML = html;

                // If unpaid, show payment form in footer
                footer.innerHTML = '';
                if((inv.status||'').toUpperCase() !== 'PAID'){
                    var form = document.createElement('form');
                    form.method = 'post';
                    form.action = '/Billing/Pay?id=' + encodeURIComponent(inv.id);
                    // clone antiforgery token
                    var af = document.getElementById('af-token');
                    if(af) form.appendChild(af.firstElementChild.cloneNode(true));
                    form.innerHTML += '<div class="row g-2 align-items-center"><div class="col"><input name="amount" class="form-control" placeholder="Amount" value="'+((inv.totalAmount||0)-(inv.amountPaid||0))+'" /></div><div class="col"><input name="externalReference" class="form-control" placeholder="External reference (optional)" /></div><div class="col-auto"><button class="btn btn-primary">Pay</button></div></div>';
                    footer.appendChild(form);
                } else {
                    footer.innerHTML = '<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>';
                }

                var modalEl = document.getElementById('invoiceModal');
                var modal = new bootstrap.Modal(modalEl);
                modal.show();
            })
            .catch(function(err){ console.warn(err); toastr.error('Could not load invoice details'); });
        }catch(e){ console.warn(e); }
    }
});
</script>
            <div class="text-md-end mb-3 mb-md-0">
                <div class="small text-muted-custom">Visit Type: @Model.Visit?.VisitType</div>
                <div class="small text-muted-custom">@Model.Visit?.VisitAt.ToString("yyyy-MM-dd HH:mm")</div>
            </div>
            <div>
                <a asp-action="VisitEdit" asp-route-id="@Model.Visit?.Id" class="btn btn-primary-custom btn-sm me-2">
                    <i class="bi bi-pencil"></i> Edit
                </a>
                        @* Request Lab button only when patient present *@
                        @if(Model.Patient != null)
                        {
                            <a asp-controller="Lab" asp-action="Request" asp-route-patientId="@Model.Patient?.Id" asp-route-visitId="@Model.Visit?.Id" class="btn btn-outline-info btn-sm me-2">
                                <i class="bi bi-flask me-1"></i> Request Lab
                            </a>
                        }
                <a asp-action="Visits" asp-route-id="@Model.Visit?.PatientId" class="btn btn-light btn-sm">
                    <i class="bi bi-arrow-left"></i> Back
                </a>
            </div>
        </div>
    </div>

    <!-- Tabs -->
    <div class="portal-card shadow-soft">
        <div class="portal-card-header">
            Visit Activities
        </div>
        <div class="portal-card-body">

            <ul class="nav nav-tabs mb-3" role="tablist">
                <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-vitals">Vitals</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-dx">Diagnosis</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-cons">Consultations</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-rx">Prescriptions</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-inv">Invoices</a></li>
                <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-lab">Lab Requests</a></li>
            </ul>

            <div class="tab-content">

                <!-- Vitals Tab -->
                <div id="tab-vitals" class="tab-pane fade show active">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3">
                        <h6 class="mb-2 mb-md-0 page-title">Vitals</h6>
                        <a asp-action="EnterVitals" asp-route-id="@Model.Visit?.Id" class="btn btn-primary-custom btn-sm">
                            <i class="bi bi-plus-lg"></i> Add Vitals
                        </a>
                    </div>

                <!-- Lab Requests Tab -->
                <div id="tab-lab" class="tab-pane fade">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">Lab Requests</h6>
                        @if (Model.Patient != null)
                        {
                            <a asp-controller="Lab" asp-action="Request" asp-route-patientId="@Model.Patient.Id" asp-route-visitId="@Model.Visit?.Id" class="btn btn-sm btn-outline-primary">New Request</a>
                        }
                    </div>

                    @if (Model.LabRequests == null || Model.LabRequests.Length == 0)
                    {
                        <div class="text-muted-custom">No lab requests for this visit.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach(var lr in Model.LabRequests)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@(lr.CreatedAt.HasValue ? lr.CreatedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm") : lr.Id.ToString()) - @(lr.PatientName ?? "")</div>
                                        <div class="small text-muted">Status: @lr.Status • Invoice: @(lr.InvoiceStatus ?? "-") • Items: @lr.ItemsCount • Results: @(lr.ResultsStatus ?? "-")</div>
                                    </div>
                                    <div>
                                        <a asp-controller="Lab" asp-action="Details" asp-route-id="@lr.Id" class="btn btn-sm btn-outline-secondary me-2">View</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                    @if (Model.RecentVitals == null || Model.RecentVitals.Length == 0)
                    {
                        <div class="text-muted-custom">No vitals recorded for this visit.</div>
                    }
                    else
                    {
                        <div class="row g-3">
                            @foreach (var v in Model.RecentVitals)
                            {
                                <div class="col-12 col-md-6 col-lg-4">
                                    <div class="portal-card shadow-soft h-100">
                                        <div class="portal-card-header d-flex justify-content-between align-items-center bg-gradient-primary text-white">
                                            <small class="fw-bold">@v.RecordedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</small>
                                            <a asp-action="VisitDetails" asp-route-id="@v.VisitId" class="btn btn-light btn-sm">
                                                <i class="bi bi-eye"></i>
                                            </a>
                                        </div>
                                        <div class="portal-card-body">
                                            <div class="mb-2"><i class="bi bi-thermometer-half me-1"></i><strong>Temp:</strong> @(v.Temperature.HasValue? v.Temperature.Value.ToString("F1") + " °C" : "-")</div>
                                            <div class="mb-2"><i class="bi bi-heart-pulse me-1"></i><strong>Pulse:</strong> @(v.PulseRate.HasValue? v.PulseRate.Value + " bpm" : "-")</div>
                                            <div class="mb-2"><i class="bi bi-lungs me-1"></i><strong>Resp:</strong> @(v.RespiratoryRate.HasValue? v.RespiratoryRate.Value + " /min" : "-")</div>
                                            <div class="mb-2"><i class="bi bi-activity me-1"></i><strong>BP:</strong> @((v.SystolicBP.HasValue ? v.SystolicBP.Value.ToString() : "-") + "/" + (v.DiastolicBP.HasValue ? v.DiastolicBP.Value.ToString() : "-") + " mmHg")</div>
                                            <div class="mb-2"><i class="bi bi-droplet-half me-1"></i><strong>O₂:</strong> @(v.OxygenSaturation.HasValue? v.OxygenSaturation.Value + " %" : "-")</div>
                                            <div class="mb-2"><i class="bi bi-weight me-1"></i><strong>Weight:</strong> @(v.WeightKg.HasValue? v.WeightKg.Value.ToString("F2") + " kg" : "-")</div>
                                            <div class="mb-2"><i class="bi bi-person me-1"></i><strong>Height:</strong> @(v.HeightCm.HasValue? v.HeightCm.Value.ToString("F2") + " cm" : "-")</div>
                                            <div class="mb-2"><i class="bi bi-calculator me-1"></i><strong>BMI:</strong> @(v.BMI.HasValue? v.BMI.Value.ToString("F2") : "-")</div>
                                            <div class="mb-2"><i class="bi bi-droplet me-1"></i><strong>BS:</strong> @(v.BloodSugar.HasValue? v.BloodSugar.Value.ToString("F2") : "-")</div>

                                            @if (!string.IsNullOrWhiteSpace(v.Notes))
                                            {
                                                <div class="mt-2">
                                                    <strong>Notes:</strong>
                                                    <div class="border rounded p-2 bg-hover">@v.Notes</div>
                                                </div>
                                            }
                                        </div>
                                        <div class="portal-card-footer text-muted-custom text-end small">
                                          
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Diagnosis Tab -->
                <div id="tab-dx" class="tab-pane fade">
                 
                        <div class="text-muted-custom">No diagnoses recorded for this visit.</div>
                 
                </div>

                <!-- Consultations Tab -->
                <div id="tab-cons" class="tab-pane fade">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3">
                        <h6 class="mb-2 mb-md-0 page-title">Consultations</h6>
                        <a asp-action="CreateConsultation" asp-route-visitId="@Model.Visit?.Id" class="btn btn-primary-custom btn-sm">
                            <i class="bi bi-plus-lg"></i> Add Consultation
                        </a>
                    </div>

                    @if (Model.Consultations == null || Model.Consultations.Length == 0)
                    {
                        <div class="text-muted-custom">No consultations recorded for this visit.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach(var c in Model.Consultations)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@c.ChiefComplaint</div>
                                        <div class="small text-muted">@c.ConsultationAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm") • Provider: @(ViewBag.ProvidersMap != null && ViewBag.ProvidersMap.ContainsKey(c.DoctorId ?? Guid.Empty) ? ViewBag.ProvidersMap[c.DoctorId ?? Guid.Empty] : (c.DoctorId?.ToString() ?? "-"))</div>
                                    </div>
                                    <div class="small text-muted">@c.Status</div>
                                    <div class="ms-2">
                                        <a asp-action="ConsultationDetails" asp-route-id="@c.Id" class="btn btn-sm btn-outline-secondary">View</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }

                </div>

                <!-- Invoices Tab -->
                <div id="tab-rx" class="tab-pane fade">
                    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3">
                        <h6 class="mb-2 mb-md-0 page-title">Prescriptions</h6>
                        @if (Model.Patient != null && Model.Visit != null)
                        {
                            <a asp-controller="Pharmacy"
                               asp-action="CreatePrescription"
                               asp-route-patientId="@Model.Patient.Id"
                               asp-route-visitId="@Model.Visit.Id"
                               asp-route-returnUrl="@Url.Action("VisitDetails", "Patients", new { id = Model.Visit.Id })"
                               class="btn btn-primary-custom btn-sm">
                                <i class="bi bi-plus-lg"></i> Add Prescription
                            </a>
                        }
                    </div>

                    @if (Model.Prescriptions == null || Model.Prescriptions.Length == 0)
                    {
                        <div class="text-muted-custom">No prescriptions recorded for this visit.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach (var prescription in Model.Prescriptions)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-start">
                                    <div>
                                        <div class="fw-semibold">@prescription.Status</div>
                                        <div class="small text-muted">@(prescription.Items?.Length ?? 0) medication item(s)</div>
                                        <div class="small text-muted">
                                            @string.Join(", ", (prescription.Items ?? Array.Empty<HMS.UI.Models.Pharmacy.PrescriptionItemViewModel>()).Take(3).Select(item => item.MedicationName))
                                        </div>
                                    </div>
                                    <div class="ms-3">
                                        <a asp-controller="Pharmacy" asp-action="PrescriptionDetails" asp-route-id="@prescription.Id" class="btn btn-sm btn-outline-secondary">View</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>

                <div id="tab-inv" class="tab-pane fade">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h6 class="mb-0">Invoices</h6>
                    </div>

                    @if (Model.Invoices == null || Model.Invoices.Length == 0)
                    {
                        <div class="text-muted-custom">No invoices recorded for this visit.</div>
                    }
                    else
                    {
                        <div class="list-group">
                            @foreach(var inv in Model.Invoices)
                            {
                                <div class="list-group-item d-flex justify-content-between align-items-center">
                                    <div>
                                        <div class="fw-semibold">@inv.InvoiceNumber</div>
                                        <div class="small text-muted">Total: @inv.TotalAmount @inv.Currency • Paid: @inv.AmountPaid</div>
                                    </div>
                                    <div>
                                        <a href="/Billing/Details?id=@inv.Id" class="btn btn-sm btn-outline-secondary me-2">View</a>
                                        <a href="/Billing/Details?id=@inv.Id" class="btn btn-sm btn-primary">Pay</a>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                 
                </div>

            </div>
        </div>
    </div>

</div>
