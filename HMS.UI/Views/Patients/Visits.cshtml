@model HMS.UI.Models.VisitViewModel[]
@using System.Linq
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Patient Visit";
    var pidObj = ViewData["PatientId"];
    var pid = pidObj is Guid g
        ? g
        : (pidObj is string s && Guid.TryParse(s, out var gg) ? gg : Guid.Empty);
}

<div class="container-fluid py-3">

    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-3">
        <div>
            <h4 class="mb-0">
                <i class="bi bi-journal-medical me-2 text-primary"></i>
                Visits
            </h4>
            <small class="text-muted">Patient visit history</small>
        </div>

        <a href="/Patients/CreateVisit?patientId=@pid"
           class="btn btn-primary btn-sm shadow-sm">
            <i class="bi bi-plus-circle me-1"></i>
            Add Visit
        </a>
    </div>

    <!-- Card wrapper -->
    <div class="card border-0 shadow-sm">
        <div class="card-body p-0">

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>
                                <i class="bi bi-calendar-event me-1"></i> Date
                            </th>
                            <th>
                                <i class="bi bi-tag me-1"></i> Type
                            </th>
                            <th>
                                <i class="bi bi-chat-left-text me-1"></i> Notes
                            </th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Length > 0)
                        {
                            foreach (var v in Model.OrderByDescending(x => x.VisitAt))
                            {
                                <tr>
                                    <td>
                                        <span class="fw-semibold">
                                            @v.VisitAt.ToString("yyyy-MM-dd")
                                        </span>
                                        <div class="text-muted small">
                                            @v.VisitAt.ToString("HH:mm")
                                        </div>
                                    </td>

                                    <td>
                                        <span class="badge bg-info text-dark">
                                            @v.VisitType
                                        </span>
                                    </td>

                                    <td>
                                        <span class="text-muted">
                                            @{
                                                var notes = v.Notes ?? "";
                                                var preview = notes.Length > 120
                                                ? notes.Substring(0, 120) + "..."
                                                : notes;
                                            }
                                            @preview
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <div class="btn-group btn-group-sm">

                                            <a href="/Patients/VisitEdit/@v.Id"
                                               class="btn btn-outline-secondary">
                                                <i class="bi bi-pencil-square"></i>
                                            </a>

                                            <a href="/Patients/VisitDetails/@v.Id" class="btn btn-outline-info">
                                                <i class="bi bi-eye"></i>
                                            </a>

                                            <a href="/Patients/EnterVitals/@v.Id" class="btn btn-outline-success">
                                                <i class="bi bi-plus-square"></i>
                                            </a>

                                            <form method="post"
                                                  asp-action="DeleteVisit"
                                                  asp-controller="Patients"
                                                  onsubmit="return confirm('Delete this visit?');">
                                                @Html.AntiForgeryToken()

                                                <input type="hidden" name="id" value="@v.Id" />
                                                <input type="hidden" name="patientId" value="@v.PatientId" />

                                                <button type="submit"
                                                        class="btn btn-outline-danger">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>

                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-4 text-muted">
                                    <i class="bi bi-inbox me-1"></i>
                                    No visits found
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
</div>