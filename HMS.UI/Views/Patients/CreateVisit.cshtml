@model HMS.UI.Models.VisitCreateViewModel

@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Create Visit";
}

<div class="page-content">
    <div class="portal-card">
        <div class="portal-card-header">Create Visit</div>
        <div class="portal-card-body">
            <form asp-action="CreateVisit" method="post">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="PatientId" />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label">Visit Date</label>
                        <input name="VisitAtDate" type="date" class="form-control" value="@Model.VisitAt.UtcDateTime.ToString("yyyy-MM-dd")" />
                    </div>
                    
                    <div class="col-md-3">
                        <label class="form-label">Time</label>
                        <input name="VisitAtTime" type="time" class="form-control" value="@Model.VisitAt.UtcDateTime.ToString("HH:mm")" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Visit Type</label>
                       <select asp-for="VisitType" class="form-select" id="VisitTypeSelect">
    <option value="">Select</option>
    @foreach(var t in (ViewBag.VisitTypes as string[] ?? Array.Empty<string>()))
    {
        var selected = string.Equals(t, Model.VisitType, StringComparison.OrdinalIgnoreCase) ? "selected" : "";
        @:<option value="@t" @selected>@t</option>
    }
</select>
                    </div>
                </div>
                @* Hidden field that will contain combined ISO datetime for model binding *@
                <input asp-for="VisitAt" type="hidden" id="VisitAtHidden" />

                <div class="mb-3">
                    <label class="form-label">Notes</label>
                    <textarea asp-for="Notes" class="form-control" rows="4"></textarea>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-primary">Save</button>
                    <a asp-action="Details" asp-route-id="@Model.PatientId" class="btn btn-light">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    (function(){
        try{
            const date = document.querySelector('input[name="VisitAtDate"]');
            const time = document.querySelector('input[name="VisitAtTime"]');
            const hidden = document.getElementById('VisitAtHidden');
            function setHidden(){
                const d = date?.value;
                const t = time?.value || '00:00';
                if(!d) return;
                const dt = new Date(d + 'T' + t);
                if(hidden) hidden.value = dt.toISOString();
            }
            date?.addEventListener('change', setHidden);
            time?.addEventListener('change', setHidden);
            setHidden();
        }catch(e){ }
    })();
</script>