@model HMS.UI.Models.Users.UserEditViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Manage User";
    var roles = Model.Roles ?? Array.Empty<HMS.UI.Models.Users.RoleViewModel>();
    var assigned = Model.AssignedRoleIds ?? Array.Empty<Guid>();
    var initials = (string.Concat((Model.FirstName ?? Model.Username).Take(1), (Model.LastName ?? string.Empty).Take(1))).ToUpperInvariant();
    if (string.IsNullOrWhiteSpace(initials))
    {
        initials = "U";
    }
}

<div class="container py-4">
    <div class="row g-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-3">
                <div>
                    <h3 class="mb-1">Manage User</h3>
                    <p class="text-muted mb-0">Update profile details, roles, account status, and credentials.</p>
                </div>
                <div class="d-flex gap-2">
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-info">
                        <i class="bi bi-eye me-1"></i>View details
                    </a>
                    <a asp-action="Index" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-1"></i>Back
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body text-center">
                    @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
                    {
                        <img src="@Model.PhotoUrl" alt="Profile photo" class="rounded-circle mb-3" style="width:96px;height:96px;object-fit:cover;" />
                    }
                    else
                    {
                        <div class="rounded-circle bg-primary-subtle text-primary d-inline-flex align-items-center justify-content-center mb-3" style="width:96px;height:96px;font-size:2rem;">
                            @initials
                        </div>
                    }

                    <h5 class="mb-1">@Model.Username</h5>
                    <p class="text-muted mb-3">@Model.Email</p>
                    <div class="d-flex justify-content-center gap-2 flex-wrap">
                        <span class="badge @(Model.IsLocked ? "text-bg-danger" : "text-bg-success")">
                            @(Model.IsLocked ? "Locked" : "Active")
                        </span>
                        @if (!string.IsNullOrWhiteSpace(Model.TenantName))
                        {
                            <span class="badge text-bg-light">@Model.TenantName</span>
                        }
                    </div>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body">
                    <h5 class="card-title">Account Actions</h5>
                    <partial name="_StatusAlerts" />

                    <form asp-action="AdminAction" method="post" class="d-grid gap-2 mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        @if (Model.IsLocked)
                        {
                            <button type="submit" name="action" value="unlock" class="btn btn-outline-success">
                                <i class="bi bi-unlock me-1"></i>Unlock account
                            </button>
                        }
                        else
                        {
                            <button type="submit" name="action" value="lock" class="btn btn-outline-danger">
                                <i class="bi bi-lock me-1"></i>Lock account
                            </button>
                        }
                    </form>

                    <form asp-action="AdminAction" method="post" class="mb-3">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <input type="hidden" name="action" value="reset" />
                        <label class="form-label">Reset password</label>
                        <input name="newPassword" type="password" class="form-control mb-2" minlength="8" required />
                        <button type="submit" class="btn btn-warning w-100">
                            <i class="bi bi-key me-1"></i>Set temporary password
                        </button>
                    </form>

                    <form asp-action="Delete" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@Model.Id" />
                        <button type="submit" class="btn btn-outline-danger w-100">
                            <i class="bi bi-trash me-1"></i>Delete user
                        </button>
                    </form>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <form asp-action="Edit" method="post" enctype="multipart/form-data" class="row g-4">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="Id" />

                        <div class="col-12">
                            <h5 class="mb-3">Profile Details</h5>
                            <div class="row g-3">
                                <div class="col-md-4">
                                    <label asp-for="FirstName" class="form-label">First name</label>
                                    <input asp-for="FirstName" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="LastName" class="form-label">Last name</label>
                                    <input asp-for="LastName" class="form-control" />
                                </div>
                                <div class="col-md-4">
                                    <label asp-for="OtherNames" class="form-label">Other names</label>
                                    <input asp-for="OtherNames" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Email" class="form-label">Email address</label>
                                    <input asp-for="Email" type="email" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="PhoneNumber" class="form-label">Phone number</label>
                                    <input asp-for="PhoneNumber" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="Department" class="form-label">Department</label>
                                    <input asp-for="Department" class="form-control" />
                                </div>
                                <div class="col-md-6">
                                    <label asp-for="JobTitle" class="form-label">Job title</label>
                                    <input asp-for="JobTitle" class="form-control" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Profile photo</label>
                                    <input name="photo" type="file" class="form-control" accept="image/*" />
                                </div>
                                <div class="col-12">
                                    <label class="form-label">Optional new password</label>
                                    <input name="newPassword" type="password" class="form-control" minlength="8" />
                                </div>
                            </div>
                        </div>

                        <div class="col-12">
                            <h5 class="mb-3">Role Assignments</h5>
                            <div class="row g-3">
                                @foreach (var role in roles)
                                {
                                    <div class="col-md-6">
                                        <label class="card h-100 border-0 bg-light">
                                            <div class="card-body">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" name="AssignedRoleIds" value="@role.Id"
                                                           @(assigned.Contains(role.Id) ? "checked" : null) />
                                                    <span class="fw-semibold ms-2">@role.Name</span>
                                                </div>
                                                <p class="text-muted small mt-2 mb-0">@role.Description</p>
                                            </div>
                                        </label>
                                    </div>
                                }
                            </div>
                        </div>

                        <div class="col-12 d-flex justify-content-end">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save me-1"></i>Save changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
