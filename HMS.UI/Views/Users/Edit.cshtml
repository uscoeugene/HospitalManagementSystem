@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Edit User Roles";
}

@{
    var user = ViewBag.User;
    var roles = ViewBag.Roles as HMS.UI.Models.Users.RoleViewModel[] ?? Array.Empty<HMS.UI.Models.Users.RoleViewModel>();
    var assigned = ViewBag.Assigned as Guid[] ?? Array.Empty<Guid>();
}

<div class="container py-4">
    <h3>Edit Roles</h3>
    <div class="mb-3">
        <strong>User:</strong> @(user?.GetType().GetProperty("Username")?.GetValue(user) ?? "-")
    </div>

    <form method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@(user?.GetType().GetProperty("Id")?.GetValue(user))" />
        <div class="mb-3">
            @foreach(var r in roles)
            {
                var isChecked = assigned.Contains(r.Id);
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="roles" value="@r.Id" @(isChecked?"checked":"") />
                    <label class="form-check-label">@r.Name - @r.Description</label>
                </div>
            }
        </div>
        <button class="btn btn-primary">Save</button>
    </form>
</div>
