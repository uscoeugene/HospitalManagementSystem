@model HMS.UI.Models.Users.UserEditViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Edit User Roles";
    var roles = Model.Roles ?? Array.Empty<HMS.UI.Models.Users.RoleViewModel>();
    var assigned = Model.AssignedRoleIds ?? Array.Empty<Guid>();
}

<div class="container py-4">
    <h3>Edit Roles</h3>
    <div class="mb-3 d-flex align-items-center gap-3">
        <div>
            @if (!string.IsNullOrWhiteSpace(Model.PhotoUrl))
            {
                <img src="@Model.PhotoUrl" alt="avatar" style="width:64px;height:64px;object-fit:cover;" class="rounded-circle" />
            }
            else
            {
                <div class="avatar-sm">@((Model?.Username ?? "").FirstOrDefault().ToString().ToUpper())</div>
            }
        </div>
        <div>
            <strong>User:</strong> @Model.Username
            <div class="text-muted small">Name: @( (Model.FirstName ?? string.Empty) + " " + (Model.LastName ?? string.Empty) )</div>
            <div class="text-muted small">Hospital: @(Model.TenantName ?? "-")</div>
        </div>
    </div>

    <div class="mb-3">
        <form method="post" asp-action="AdminAction" onsubmit="return confirm('Are you sure?');" style="display:inline-block;">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <button name="action" value="lock" class="btn btn-outline-danger btn-sm me-2">Lock</button>
            <button name="action" value="unlock" class="btn btn-outline-success btn-sm me-2">Unlock</button>
        </form>

        <button type="button" class="btn btn-outline-warning btn-sm" data-bs-toggle="modal" data-bs-target="#resetModal">Reset Password</button>
    </div>

    <form method="post" enctype="multipart/form-data">
        @Html.AntiForgeryToken()
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="mb-3 row">
            <div class="col-md-4">
                <label class="form-label">First name</label>
                <input class="form-control" name="firstName" value="@(Model.FirstName ?? "")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Last name</label>
                <input class="form-control" name="lastName" value="@(Model.LastName ?? "")" />
            </div>
            <div class="col-md-4">
                <label class="form-label">Email</label>
                <input class="form-control" name="email" value="@(Model.Email ?? "")" />
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Upload Photo</label>
            <input type="file" name="photo" class="form-control" accept="image/*" />
        </div>
        <div class="mb-3">
            @foreach(var r in roles)
            {
                var isChecked = assigned.Contains(r.Id);
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="roles" value="@r.Id" @(isChecked?"checked":"") />
                    <label class="form-check-label">@r.Name - @r.Description</label>
                </div>
            }
        </div>
        <button class="btn btn-primary">Save</button>
    </form>
</div>

<!-- Reset password modal -->
<div class="modal fade" id="resetModal" tabindex="-1" aria-labelledby="resetModalLabel" aria-hidden="true">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="resetModalLabel">Reset User Password</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <form method="post" asp-action="AdminAction" onsubmit="return validateResetPassword();">
      <div class="modal-body">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <input type="hidden" name="action" value="reset" />
            <div class="mb-3">
                <label class="form-label">Temporary password</label>
                <input id="tempPass" name="newPassword" type="password" class="form-control" required />
                <div id="pwHelp" class="form-text">Minimum 8 chars, include uppercase, lowercase, digit and special char.</div>
            </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
        <button type="submit" class="btn btn-warning">Reset Password</button>
      </div>
      </form>
    </div>
  </div>
</div>

<script>
function validateResetPassword(){
    var p = document.getElementById('tempPass').value || '';
    // enforce complexity: min8, upper, lower, digit, special
    var ok = p.length >= 8 && /[A-Z]/.test(p) && /[a-z]/.test(p) && /[0-9]/.test(p) && /[^A-Za-z0-9]/.test(p);
    if(!ok){
        alert('Password does not meet complexity requirements.');
        return false;
    }
    return true;
}
</script>
