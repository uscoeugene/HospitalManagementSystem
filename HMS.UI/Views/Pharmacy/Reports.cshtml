@model HMS.UI.Models.Pharmacy.PharmacyReportsViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Pharmacy Reports";
}

<div class="container py-4">
    <h3>Pharmacy Reports</h3>

    <h5 class="mt-4">Stock Shortages</h5>
    <table class="table">
        <thead><tr><th>Code</th><th>Name</th><th class="text-end">Stock</th><th class="text-end">Reserved</th></tr></thead>
        <tbody>
            @foreach(var s in Model.Shortages)
            {
                <tr>
                    <td>@s.InventoryItemCode</td>
                    <td>@s.InventoryItemName</td>
                    <td class="text-end">@s.Stock</td>
                    <td class="text-end">@s.Reserved</td>
                </tr>
            }
        </tbody>
    </table>

    <h5 class="mt-4">Daily Dispenses</h5>
    <table class="table">
        <thead><tr><th>Date</th><th class="text-end">Dispensed</th></tr></thead>
        <tbody>
            @foreach(var d in Model.Daily)
            {
                <tr>
                    <td>@d.Date.ToString("yyyy-MM-dd")</td>
                    <td class="text-end">@d.DispensedCount</td>
                </tr>
            }
        </tbody>
    </table>

    <h5 class="mt-4">Revenue per Inventory Item</h5>
    <table class="table">
        <thead><tr><th>Item</th><th class="text-end">Revenue</th></tr></thead>
        <tbody>
            @foreach(var r in Model.Revenue)
            {
                <tr>
                    <td>@r.InventoryItemName</td>
                    <td class="text-end">@r.Revenue</td>
                </tr>
            }
        </tbody>
    </table>
</div>
