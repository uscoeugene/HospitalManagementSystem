@model HMS.UI.Models.Pharmacy.InventoryItemViewModel[]
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Inventory";
}

<div class="container py-4">
    <h3>Inventory</h3>

    @if(TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <div class="mb-3 text-end">
        <a class="btn btn-success" href="/Pharmacy/CreateInventory">New Item</a>
    </div>

    <table class="table table-hover">
        <thead><tr><th>Code</th><th>Name</th><th>Category</th><th class="text-end">Stock</th><th class="text-end">Actions</th></tr></thead>
        <tbody>
            @if(Model != null && Model.Length > 0)
            {
                foreach(var it in Model)
                {
                    <tr>
                        <td>@it.Code</td>
                        <td>@it.Name</td>
                        <td>@it.Category</td>
                        <td class="text-end">@it.Stock</td>
                        <td class="text-end">
                            <a class="btn btn-sm btn-outline-primary" href="@Url.Action("InventoryDetails", "Pharmacy", new { id = it.Id })">View</a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="5" class="text-center text-muted">No inventory</td></tr>
            }
        </tbody></table>
</div>
