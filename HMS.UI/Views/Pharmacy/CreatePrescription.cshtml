@model HMS.UI.Models.Pharmacy.CreatePrescriptionViewModel

@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Create Prescription";
    var rows = Model.GetNormalizedItems();
}

<div class="page-content">

    <!-- HEADER -->
    <div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="page-title">
                <i class="bi bi-journal-plus me-2 text-primary"></i>
                Create Prescription
            </h1>
            <p class="page-subtitle">
                Write prescription items and route to pharmacy for reconciliation & dispensing
            </p>
        </div>

        <a class="btn btn-light border"
           asp-action="Prescriptions">

            <i class="bi bi-arrow-left me-1"></i>
            Back

        </a>

    </div>

    <!-- ALERTS -->
    <partial name="~/Views/Shared/_StatusAlerts.cshtml" />

    <form data-prescription-form method="post" asp-action="CreatePrescription">

        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="ReturnUrl" />
        <input type="hidden" asp-for="LockPatientSelection" />
        <input type="hidden" asp-for="LockVisitSelection" />

        <div class="row row-tight">

            <!-- LEFT: CLINICAL CONTEXT -->
            <div class="col-12">

                <div class="portal-card mb-3">


                    <div class="portal-card-header">
                        <i class="bi bi-person me-2 text-primary"></i>
                        Patient Information
                    </div>

                    <div class="portal-card-body">

                         <div class="row g-3">
     <div class="col-lg-6">
         <label asp-for="PatientId" class="form-label">Patient</label>
         @if (Model.LockPatientSelection)
         {
             <select asp-for="PatientId" class="form-select" data-prescription-patient disabled="disabled">
                 <option value="">Select patient</option>
                 @foreach (var patient in Model.AvailablePatients)
                 {
                     if (patient.Id == Model.PatientId)
                     {
                         <option value="@patient.Id" selected="selected">@patient.DisplayName</option>
                     }
                     else
                     {
                         <option value="@patient.Id">@patient.DisplayName</option>
                     }
                 }
             </select>
         }
         else
         {
             <select asp-for="PatientId" class="form-select" data-prescription-patient>
                 <option value="">Select patient</option>
                 @foreach (var patient in Model.AvailablePatients)
                 {
                     if (patient.Id == Model.PatientId)
                     {
                         <option value="@patient.Id" selected="selected">@patient.DisplayName</option>
                     }
                     else
                     {
                         <option value="@patient.Id">@patient.DisplayName</option>
                     }
                 }
             </select>
         }
         @if (Model.LockPatientSelection)
         {
             <input type="hidden" asp-for="PatientId" />
         }
     </div>
     <div class="col-lg-6">
         <label asp-for="VisitId" class="form-label">Visit</label>
         @if (Model.LockVisitSelection)
         {
             <select asp-for="VisitId" class="form-select" data-prescription-visit data-patient-visits-url="@Url.Action("PatientVisits", "Pharmacy")" disabled="disabled">
                 <option value="">Select visit</option>
                 @foreach (var visit in Model.AvailableVisits)
                 {
                     if (visit.Id == Model.VisitId)
                     {
                         <option value="@visit.Id" selected="selected">@visit.DisplayName</option>
                     }
                     else
                     {
                         <option value="@visit.Id">@visit.DisplayName</option>
                     }
                 }
             </select>
         }
         else
         {
             <select asp-for="VisitId" class="form-select" data-prescription-visit data-patient-visits-url="@Url.Action("PatientVisits", "Pharmacy")">
                 <option value="">Select visit</option>
                 @foreach (var visit in Model.AvailableVisits)
                 {
                     if (visit.Id == Model.VisitId)
                     {
                         <option value="@visit.Id" selected="selected">@visit.DisplayName</option>
                     }
                     else
                     {
                         <option value="@visit.Id">@visit.DisplayName</option>
                     }
                 }
             </select>
         }
         @if (Model.LockVisitSelection)
         {
             <input type="hidden" asp-for="VisitId" />
         }
     </div>
 </div>

                        <div class="small text-muted mt-2">
                            Visits update automatically when patient changes
                        </div>

                    </div>

                </div>

            </div>

            <!-- RIGHT: PRESCRIPTION ITEMS -->
            <div class="col-12">

                <div class="portal-card mb-3">

                    <div class="portal-card-header d-flex justify-content-between align-items-center">

                        <div>
                            <i class="bi bi-capsule-pill me-2 text-primary"></i>
                            Prescription Items
                        </div>

                        <button type="button"
                                class="btn btn-sm btn-primary-custom"
                                data-add-prescription-item>

                            <i class="bi bi-plus-lg me-1"></i>
                            Add Item

                        </button>

                    </div>

                    <div class="portal-card-body">

                        <div class="row row-tight"
                             data-prescription-items-container>

                            @for (var i = 0; i < rows.Length; i++)
                            {
                                <div class="col-12 col-lg-6"
                                     data-prescription-item-row>

                                    <partial name="_PrescriptionItemEditorRow"
                                             model="new HMS.UI.Models.Pharmacy.PrescriptionItemEditorRowViewModel {
                                                Index = i,
                                                Item = rows[i],
                                                AvailableInventoryItems = Model.AvailableInventoryItems
                                             }" />

                                </div>
                            }

                        </div>

                    </div>

                </div>

                <!-- ACTION FOOTER -->
                <div class="portal-card">

                    <div class="portal-card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">

                        <div class="small text-muted">
                            Prescription will be sent to pharmacy even if stock is unavailable.
                            Fulfilment happens during reconciliation.
                        </div>

                        <div class="d-flex gap-2">

                            <a class="btn btn-light border"
                               asp-action="Prescriptions">

                                Cancel

                            </a>

                            <button class="btn btn-primary-custom">

                                <i class="bi bi-check2-circle me-1"></i>
                                Create Prescription

                            </button>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </form>

</div>

<!-- DATA -->
<script type="application/json"
        id="prescription-inventory-data">

    @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
        Model.AvailableInventoryItems.Select(i => new {
            id = i.Id,
            name = i.Name,
            code = i.Code
        })
    ))

</script>

@section Scripts {
    <script src="/js/prescription-form.js?v=3"></script>
}