@model HMS.UI.Models.Pharmacy.CreatePrescriptionViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Create Prescription";
    var rows = Model.GetNormalizedItems();
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <h3 class="mb-1">Create Prescription</h3>
            <p class="text-muted mb-0">Prescribe with free text first, then optionally link stock for pharmacy reconciliation.</p>
        </div>
        <a class="btn btn-outline-secondary" asp-action="Prescriptions">Back to Prescriptions</a>
    </div>

    <partial name="~/Views/Shared/_StatusAlerts.cshtml" />

    <form data-prescription-form method="post" asp-action="CreatePrescription" class="row g-4">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="ReturnUrl" />
        <input type="hidden" asp-for="LockPatientSelection" />
        <input type="hidden" asp-for="LockVisitSelection" />
        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <div class="row g-3">
                        <div class="col-lg-6">
                            <label asp-for="PatientId" class="form-label">Patient</label>
                            @if (Model.LockPatientSelection)
                            {
                                <select asp-for="PatientId" class="form-select" data-prescription-patient disabled="disabled">
                                    <option value="">Select patient</option>
                                    @foreach (var patient in Model.AvailablePatients)
                                    {
                                        if (patient.Id == Model.PatientId)
                                        {
                                            <option value="@patient.Id" selected="selected">@patient.DisplayName</option>
                                        }
                                        else
                                        {
                                            <option value="@patient.Id">@patient.DisplayName</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <select asp-for="PatientId" class="form-select" data-prescription-patient>
                                    <option value="">Select patient</option>
                                    @foreach (var patient in Model.AvailablePatients)
                                    {
                                        if (patient.Id == Model.PatientId)
                                        {
                                            <option value="@patient.Id" selected="selected">@patient.DisplayName</option>
                                        }
                                        else
                                        {
                                            <option value="@patient.Id">@patient.DisplayName</option>
                                        }
                                    }
                                </select>
                            }
                            @if (Model.LockPatientSelection)
                            {
                                <input type="hidden" asp-for="PatientId" />
                            }
                        </div>
                        <div class="col-lg-6">
                            <label asp-for="VisitId" class="form-label">Visit</label>
                            @if (Model.LockVisitSelection)
                            {
                                <select asp-for="VisitId" class="form-select" data-prescription-visit data-patient-visits-url="@Url.Action("PatientVisits", "Pharmacy")" disabled="disabled">
                                    <option value="">Select visit</option>
                                    @foreach (var visit in Model.AvailableVisits)
                                    {
                                        if (visit.Id == Model.VisitId)
                                        {
                                            <option value="@visit.Id" selected="selected">@visit.DisplayName</option>
                                        }
                                        else
                                        {
                                            <option value="@visit.Id">@visit.DisplayName</option>
                                        }
                                    }
                                </select>
                            }
                            else
                            {
                                <select asp-for="VisitId" class="form-select" data-prescription-visit data-patient-visits-url="@Url.Action("PatientVisits", "Pharmacy")">
                                    <option value="">Select visit</option>
                                    @foreach (var visit in Model.AvailableVisits)
                                    {
                                        if (visit.Id == Model.VisitId)
                                        {
                                            <option value="@visit.Id" selected="selected">@visit.DisplayName</option>
                                        }
                                        else
                                        {
                                            <option value="@visit.Id">@visit.DisplayName</option>
                                        }
                                    }
                                </select>
                            }
                            @if (Model.LockVisitSelection)
                            {
                                <input type="hidden" asp-for="VisitId" />
                            }
                            <div class="form-text">Visits update automatically when you select a patient.</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">Prescription Items</h5>
                <button type="button" class="btn btn-outline-primary btn-sm" data-add-prescription-item>
                    <i class="bi bi-plus-lg"></i> Add Item
                </button>
            </div>
            <div class="row g-3" data-prescription-items-container>
                @for (var i = 0; i < rows.Length; i++)
                {
                    <div class="col-12 col-xl-6" data-prescription-item-row>
                        <partial name="_PrescriptionItemEditorRow" model="new HMS.UI.Models.Pharmacy.PrescriptionItemEditorRowViewModel { Index = i, Item = rows[i], AvailableInventoryItems = Model.AvailableInventoryItems }" />
                    </div>
                }
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm">
                <div class="card-body d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
                    <div class="text-muted">The prescription will move to pharmacy even if stock is unavailable. Fulfilment happens during reconciliation and dispensing.</div>
                    <div class="d-flex gap-2">
                        <a class="btn btn-light" asp-action="Prescriptions">Cancel</a>
                        <button class="btn btn-primary">Create Prescription</button>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

<script type="application/json" id="prescription-inventory-data">@Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.AvailableInventoryItems.Select(i => new { id = i.Id, name = i.Name, code = i.Code })))</script>

@section Scripts {

    <script src="/js/prescription-form.js"></script>
}
