@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Pharmacy";
}

<div class="container py-4">
    <h3>Pharmacy Dashboard</h3>
    <p class="text-muted">Quick links to pharmacy modules</p>

    <div class="row g-3 mt-3">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Inventory</h5>
                    <p class="card-text text-muted">Manage inventory items and stock.</p>
                    <div class="mt-auto">
                        <a class="btn btn-primary" asp-controller="Pharmacy" asp-action="Inventory">Open</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Drugs</h5>
                    <p class="card-text text-muted">Manage drug catalog.</p>
                    <div class="mt-auto">
                        <a class="btn btn-primary" href="/Pharmacy/Drugs">Open</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-body d-flex flex-column">
                    <h5 class="card-title">Prescriptions</h5>
                    <p class="card-text text-muted">Create and manage prescriptions.</p>
                    <div class="mt-auto">
                        <a class="btn btn-primary" href="/Pharmacy/Prescriptions">Open</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
