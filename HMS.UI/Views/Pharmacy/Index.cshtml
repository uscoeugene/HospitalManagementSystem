@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Pharmacy Dashboard";
}

<div class="page-content">

    <!-- HEADER -->
    <div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="page-title">
                <i class="bi bi-capsule me-2 text-primary"></i>
                Pharmacy Dashboard
            </h1>
            <p class="page-subtitle">
                Inventory, prescriptions, and pharmacy operations overview
            </p>
        </div>

    </div>

    <!-- KPI CARDS -->
    <div class="row row-tight mb-4">

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-primary shadow-soft">
                <h2>1,284</h2>
                <p>Total Medicines</p>
                <i class="bi bi-box-seam"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-success shadow-soft">
                <h2>96</h2>
                <p>Prescriptions Today</p>
                <i class="bi bi-file-medical"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-warning shadow-soft">
                <h2>18</h2>
                <p>Low Stock Items</p>
                <i class="bi bi-exclamation-triangle"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-danger shadow-soft">
                <h2>₦2.4M</h2>
                <p>Monthly Sales</p>
                <i class="bi bi-cash-stack"></i>
            </div>
        </div>

    </div>

    <!-- MODULE SHORTCUTS -->
    
            <div class="row row-tight">

                <!-- INVENTORY -->
                <div class="col-md-6 col-lg-4">

                    <div class="module-card portal-card h-100">

                        <div class="portal-card-body">

                            <div class="module-icon bg-gradient-primary text-white mb-3">
                                <i class="bi bi-box-seam"></i>
                            </div>

                            <h5 class="mb-1">Inventory</h5>
                            <p class="small text-muted mb-3">
                                Manage medicines, stock levels and pricing
                            </p>

                            <a class="btn btn-primary-custom w-100"
                               asp-controller="Pharmacy"
                               asp-action="Inventory">

                                Open Module
                            </a>

                        </div>

                    </div>

                </div>

                <!-- PRESCRIPTIONS -->
                <div class="col-md-6 col-lg-4">

                    <div class="module-card portal-card h-100">

                        <div class="portal-card-body">

                            <div class="module-icon bg-gradient-success text-white mb-3">
                                <i class="bi bi-file-medical"></i>
                            </div>

                            <h5 class="mb-1">Prescriptions</h5>
                            <p class="small text-muted mb-3">
                                Create and process patient prescriptions
                            </p>

                            <a class="btn btn-success-custom w-100"
                               href="/Pharmacy/Prescriptions">

                                Open Module
                            </a>

                        </div>

                    </div>

                </div>

                <!-- OPTIONAL EXTENSION -->
                <div class="col-md-6 col-lg-4">

                    <div class="module-card portal-card h-100">

                        <div class="portal-card-body">

                            <div class="module-icon bg-gradient-warning text-white mb-3">
                                <i class="bi bi-receipt"></i>
                            </div>

                            <h5 class="mb-1">Sales Reports</h5>
                            <p class="small text-muted mb-3">
                                View revenue, dispensing trends and analytics
                            </p>

                            <a class="btn btn-outline-primary w-100"
                               href="#">

                                View Reports
                            </a>

                        </div>

                    </div>

                </div>

            </div>

   
    </div>
    <!-- SECOND ROW: INSIGHT + ACTIVITY -->
    <div class="row row-tight mb-4">

        <!-- STOCK INSIGHT -->
        <div class="col-lg-6">

            <div class="portal-card">

                <div class="portal-card-header">
                    <i class="bi bi-graph-up-arrow me-2 text-primary"></i>
                    Stock Insights
                </div>

                <div class="portal-card-body">

                    <div class="d-flex justify-content-between small mb-2">
                        <span>Paracetamol</span>
                        <span class="text-danger fw-semibold">Low</span>
                    </div>

                    <div class="d-flex justify-content-between small mb-2">
                        <span>Amoxicillin</span>
                        <span class="text-success fw-semibold">In Stock</span>
                    </div>

                    <div class="d-flex justify-content-between small mb-2">
                        <span>Ibuprofen</span>
                        <span class="text-warning fw-semibold">Reorder Soon</span>
                    </div>

                    <div class="d-flex justify-content-between small">
                        <span>Vitamin C</span>
                        <span class="text-success fw-semibold">In Stock</span>
                    </div>

                </div>

            </div>

        </div>

        <!-- ACTIVITY -->
        <div class="col-lg-6">

            <div class="portal-card">

                <div class="portal-card-header">
                    <i class="bi bi-clock-history me-2 text-primary"></i>
                    Recent Activity
                </div>

                <div class="portal-card-body">

                    <div class="timeline">

                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                Dispensed <b>Amoxicillin</b> to Patient #P-1023
                                <div class="small text-muted">2 minutes ago</div>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                New prescription created by Dr. James
                                <div class="small text-muted">15 minutes ago</div>
                            </div>
                        </div>

                        <div class="timeline-item">
                            <div class="timeline-dot"></div>
                            <div class="timeline-content">
                                Stock updated: Paracetamol +200 units
                                <div class="small text-muted">1 hour ago</div>
                            </div>
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

  

</div>