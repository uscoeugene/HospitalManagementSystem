@model HMS.UI.Models.Pharmacy.PrescriptionViewModel

@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Prescription";
    var inventoryItems = ViewBag.AvailableInventoryItems as HMS.UI.Models.Pharmacy.InventoryItemViewModel[]
        ?? Array.Empty<HMS.UI.Models.Pharmacy.InventoryItemViewModel>();
}

<div class="page-content">

    <!-- HEADER -->
    <div class="page-header d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="page-title">
                <i class="bi bi-journal-medical me-2 text-primary"></i>
                Prescription #@Model.Id
            </h1>
            <p class="page-subtitle">
                Patient: <b>@(!string.IsNullOrWhiteSpace(Model.PatientDisplay) ? Model.PatientDisplay : Model.PatientId.ToString())</b>
                • Visit: <b>@(!string.IsNullOrWhiteSpace(Model.VisitDisplay) ? Model.VisitDisplay : (Model.VisitId?.ToString() ?? "Not linked"))</b>
            </p>
        </div>

        <div class="d-flex gap-2 align-items-center">

            <a class="btn btn-light border"
               asp-action="Prescriptions">

                <i class="bi bi-arrow-left me-1"></i>
                Back

            </a>

            <span class="badge bg-light text-dark border">
                @Model.Status
            </span>

        </div>

    </div>

    <!-- ALERTS -->
    <partial name="~/Views/Shared/_StatusAlerts.cshtml" />

    <!-- ITEMS WORKBENCH -->
    <div class="d-flex flex-column gap-3">

        @foreach (var it in Model.Items)
        {
            <div class="portal-card">

                <div class="portal-card-body">

                    <!-- ITEM HEADER -->
                    <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 mb-3">

                        <div>

                            <div class="fw-bold fs-5">
                                @it.MedicationName
                            </div>

                            <div class="small text-muted">
                                Linked stock:
                                @(string.IsNullOrWhiteSpace(it.InventoryItemName)
                                                            ? "Not linked"
                                                            : it.InventoryItemName)
                        </div>

                        </div>

                        <div class="d-flex flex-wrap gap-2">

                            <span class="badge-soft-warning">
                                @it.Status
                            </span>

                        @if (it.IsSubstituted && !string.IsNullOrWhiteSpace(it.SubstituteMedicationName))
                            {
                                <span class="badge-soft-danger">
                                    Sub: @it.SubstituteMedicationName
                                </span>
                            }

                            @if (it.AvailableStock.HasValue)
                            {
                                <span class="badge-soft-success">
                                    Stock: @it.AvailableStock
                                </span>
                            }

                        </div>

                    </div>

                    <!-- MEDICAL DATA -->
                    <div class="row row-tight mb-3">

                        <div class="col-6 col-md-3">
                            <div class="small text-muted">Dosage</div>
                            <div class="fw-semibold">@it.Dosage</div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="small text-muted">Frequency</div>
                            <div class="fw-semibold">@it.Frequency</div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="small text-muted">Qty</div>
                            <div class="fw-semibold">@it.Quantity</div>
                        </div>

                        <div class="col-6 col-md-3">
                            <div class="small text-muted">Dispensed</div>
                            <div class="fw-semibold">@it.DispensedQuantity</div>
                        </div>

                    </div>

                    @if (!string.IsNullOrWhiteSpace(it.ShortageReason) || !string.IsNullOrWhiteSpace(it.Notes))
                    {
                        <div class="mb-3">

                            @if (!string.IsNullOrWhiteSpace(it.ShortageReason))
                            {
                                <div class="alert alert-warning py-2 mb-2">
                                    <strong>Shortage:</strong> @it.ShortageReason
                                </div>
                            }

                            @if (!string.IsNullOrWhiteSpace(it.Notes))
                            {
                                <div class="alert alert-light border py-2 mb-0">
                                    <strong>Notes:</strong> @it.Notes
                                </div>
                            }

                        </div>
                    }

                    <!-- ACTIONS (SMART COLLAPSIBLE WORKBENCH) -->
                    <div class="d-flex flex-column gap-2">

                        <!-- RECONCILIATION TOGGLE -->
                        <button class="btn btn-light border w-100 d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#rec_@it.Id">

                            <span>
                                <i class="bi bi-arrow-repeat me-2"></i>
                                Reconciliation
                            </span>

                            <i class="bi bi-chevron-down collapse-icon"></i>

                        </button>

                        <div class="collapse" id="rec_@it.Id">

                            <div class="portal-card border mt-2">
                                <div class="portal-card-body">

                                    <form method="post" asp-action="ReconcilePrescriptionItem">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="prescriptionId" value="@Model.Id" />
                                        <input type="hidden" name="itemId" value="@it.Id" />

                                        <div class="row g-3">

                                            <div class="col-md-6">
                                                <label class="form-label">Stock Link</label>
                                                <select name="inventoryItemId" class="form-select">
                                                    <option value="">No link</option>
                                                    @foreach (var inv in inventoryItems)
                                                    {
                                                        <option value="@inv.Id"
                                                                selected="@(inv.Id == it.InventoryItemId)">
                                                            @inv.Name
                                                        </option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Status</label>
                                                <select name="status" class="form-select">
                                                    @{
                                                        var statuses = new[]
                                                        { "PENDING","READY","OUT_OF_STOCK","ORDER_STOCK",
                                                                                                "UNAVAILABLE","PARTIALLY_DISPENSED","DISPENSED","SUBSTITUTED" };

                                                        foreach (var s in statuses)
                                                        {
                                                            <option value="@s" selected="@(s == it.Status)">
                                                                @s
                                                            </option>
                                                        }
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Substitute</label>
                                                <input name="substituteMedicationName"
                                                       class="form-control"
                                                       value="@it.SubstituteMedicationName" />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Notes</label>
                                                <textarea name="note"
                                                      class="form-control"
                                                      rows="2">@it.Notes</textarea>
                                            </div>

                                        </div>

                                        <button class="btn btn-outline-primary w-100 mt-3">
                                            Save Reconciliation
                                        </button>

                                    </form>

                                </div>
                            </div>

                        </div>

                        <!-- DISPENSE TOGGLE -->
                        <button class="btn btn-primary w-100 d-flex justify-content-between align-items-center"
                                type="button"
                                data-bs-toggle="collapse"
                                data-bs-target="#disp_@it.Id">

                            <span>
                                <i class="bi bi-capsule me-2"></i>
                                Dispense Medication
                            </span>

                            <i class="bi bi-chevron-down collapse-icon"></i>

                        </button>

                        <div class="collapse" id="disp_@it.Id">

                            <div class="portal-card border mt-2">
                                <div class="portal-card-body">

                                    <form method="post" asp-action="Dispense">

                                        @Html.AntiForgeryToken()

                                        <input type="hidden" name="prescriptionId" value="@Model.Id" />
                                        <input type="hidden" name="itemId" value="@it.Id" />

                                        <div class="row g-3">

                                            <div class="col-md-4">
                                                <label class="form-label">Quantity</label>
                                                <input type="number"
                                                       name="quantity"
                                                       class="form-control"
                                                       value="1"
                                                       min="1" />
                                            </div>

                                            <div class="col-md-8">
                                                <label class="form-label">Inventory</label>
                                                <select name="inventoryItemId" class="form-select">
                                                    <option value="">Linked item</option>
                                                    @foreach (var inv in inventoryItems)
                                                    {
                                                        <option value="@inv.Id"
                                                                selected="@(inv.Id == it.InventoryItemId)">
                                                            @inv.Name
                                                        </option>
                                                    }
                                                </select>
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Dispensed Name</label>
                                                <input name="dispensedMedicationName"
                                                       class="form-control"
                                                       placeholder="Optional substitute" />
                                            </div>

                                            <div class="col-md-6">
                                                <label class="form-label">Credit Reason</label>
                                                <input name="reason"
                                                       class="form-control"
                                                       placeholder="Optional" />
                                            </div>

                                            <div class="col-12">
                                                <label class="form-label">Note</label>
                                                <textarea name="note"
                                                      class="form-control"
                                                      rows="2"></textarea>
                                            </div>

                                            <div class="col-12">
                                                <div class="form-check">
                                                    <input class="form-check-input"
                                                           type="checkbox"
                                                           name="allowOnCredit"
                                                           value="true"
                                                           id="credit_@it.Id">
                                                    <label class="form-check-label" for="credit_@it.Id">
                                                        Allow billing on credit
                                                    </label>
                                                </div>
                                            </div>

                                        </div>

                                        <button class="btn btn-primary w-100 mt-3">
                                            Dispense
                                        </button>

                                    </form>

                                </div>
                            </div>

                        </div>

                    </div>

                </div>

            </div>
        }

    </div>

</div>