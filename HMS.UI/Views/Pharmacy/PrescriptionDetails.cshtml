@model HMS.UI.Models.Pharmacy.PrescriptionViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Prescription";
    var inventoryItems = ViewBag.AvailableInventoryItems as HMS.UI.Models.Pharmacy.InventoryItemViewModel[] ?? Array.Empty<HMS.UI.Models.Pharmacy.InventoryItemViewModel>();
}

<div class="container-fluid py-4">
    <div class="d-flex flex-column flex-lg-row align-items-lg-center justify-content-between gap-3 mb-4">
        <div>
            <h3 class="mb-1">Prescription Details</h3>
            <p class="text-muted mb-0">Pharmacy can reconcile shortages, substitute items, partially dispense, and raise billing after fulfilment.</p>
        </div>
        <div class="d-flex gap-2">
            <a class="btn btn-outline-secondary" asp-action="EditPrescription" asp-route-id="@Model.Id">Edit Prescription</a>
            <span class="badge rounded-pill text-bg-light align-self-center">@Model.Status</span>
        </div>
    </div>

    <partial name="~/Views/Shared/_StatusAlerts.cshtml" />

    <div class="row g-4 mb-4">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Prescription Id</div>
                    <div class="fw-semibold text-break">@Model.Id</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Patient Id</div>
                    <div class="fw-semibold text-break">@Model.PatientId</div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="text-muted small mb-1">Visit Id</div>
                    <div class="fw-semibold text-break">@(Model.VisitId?.ToString() ?? "Not linked")</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var it in Model.Items)
        {
            <div class="col-12">
                <div class="card border-0 shadow-sm">
                    <div class="card-body">
                        <div class="d-flex flex-column flex-xl-row justify-content-between gap-3 mb-4">
                            <div>
                                <h5 class="mb-1">@it.MedicationName</h5>
                                <div class="text-muted">Linked stock: @(string.IsNullOrWhiteSpace(it.InventoryItemName) ? "Not linked" : it.InventoryItemName)</div>
                            </div>
                            <div class="d-flex flex-wrap gap-2">
                                <span class="badge text-bg-primary">@it.Status</span>
                                @if (it.IsSubstituted && !string.IsNullOrWhiteSpace(it.SubstituteMedicationName))
                                {
                                    <span class="badge text-bg-warning">Substitute: @it.SubstituteMedicationName</span>
                                }
                                @if (it.AvailableStock.HasValue)
                                {
                                    <span class="badge text-bg-light">Stock: @it.AvailableStock.Value</span>
                                }
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-2">
                                <div class="text-muted small mb-1">Dosage</div>
                                <div>@(string.IsNullOrWhiteSpace(it.Dosage) ? "-" : it.Dosage)</div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small mb-1">Frequency</div>
                                <div>@(string.IsNullOrWhiteSpace(it.Frequency) ? "-" : it.Frequency)</div>
                            </div>
                            <div class="col-md-2">
                                <div class="text-muted small mb-1">Prescribed Qty</div>
                                <div>@it.Quantity</div>
                            </div>
                            <div class="col-md-2">
                                <div class="text-muted small mb-1">Dispensed Qty</div>
                                <div>@it.DispensedQuantity</div>
                            </div>
                            <div class="col-md-3">
                                <div class="text-muted small mb-1">Price</div>
                                <div>@it.Currency @it.Price</div>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(it.ShortageReason) || !string.IsNullOrWhiteSpace(it.Notes))
                        {
                            <div class="row g-3 mb-4">
                                @if (!string.IsNullOrWhiteSpace(it.ShortageReason))
                                {
                                    <div class="col-12">
                                        <div class="alert alert-warning mb-0">
                                            <strong>Shortage:</strong> @it.ShortageReason
                                        </div>
                                    </div>
                                }
                                @if (!string.IsNullOrWhiteSpace(it.Notes))
                                {
                                    <div class="col-12">
                                        <div class="alert alert-light border mb-0">
                                            <strong>Notes:</strong> @it.Notes
                                        </div>
                                    </div>
                                }
                            </div>
                        }

                        <div class="row g-4">
                            <div class="col-12 col-xl-6">
                                <form method="post" asp-action="ReconcilePrescriptionItem" class="card bg-light border-0 h-100">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="prescriptionId" value="@Model.Id" />
                                    <input type="hidden" name="itemId" value="@it.Id" />
                                    <div class="card-body">
                                        <h6 class="card-title">Pharmacy Reconciliation</h6>
                                        <div class="row g-3">
                                            <div class="col-12">
                                                <label class="form-label">Link or relink stock item</label>
                                                <select name="inventoryItemId" class="form-select">
                                                    <option value="">No inventory link</option>
                                                    @foreach (var inventoryItem in inventoryItems)
                                                    {
                                                        if (inventoryItem.Id == it.InventoryItemId)
                                                        {
                                                            <option value="@inventoryItem.Id" selected="selected">@inventoryItem.Name (@inventoryItem.Code)</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@inventoryItem.Id">@inventoryItem.Name (@inventoryItem.Code)</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Fulfilment status</label>
                                                <select name="status" class="form-select">
                                                    @{
                                                        var statuses = new[] { "PENDING", "READY", "OUT_OF_STOCK", "ORDER_STOCK", "UNAVAILABLE", "PARTIALLY_DISPENSED", "DISPENSED", "SUBSTITUTED" };
                                                        foreach (var status in statuses)
                                                        {
                                                            if (string.Equals(status, it.Status, StringComparison.OrdinalIgnoreCase))
                                                            {
                                                                <option value="@status" selected="selected">@status</option>
                                                            }
                                                            else
                                                            {
                                                                <option value="@status">@status</option>
                                                            }
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Substitute medication</label>
                                                <input name="substituteMedicationName" value="@it.SubstituteMedicationName" class="form-control" placeholder="Optional alternative" />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Pharmacy note</label>
                                                <textarea name="note" class="form-control" rows="3" placeholder="Explain shortage, sourcing, substitution, or dispensing plan">@it.Notes</textarea>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 pt-0">
                                        <button class="btn btn-outline-primary">Save Reconciliation</button>
                                    </div>
                                </form>
                            </div>

                            <div class="col-12 col-xl-6">
                                <form method="post" asp-action="Dispense" class="card bg-light border-0 h-100">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="prescriptionId" value="@Model.Id" />
                                    <input type="hidden" name="itemId" value="@it.Id" />
                                    <div class="card-body">
                                        <h6 class="card-title">Dispense Medication</h6>
                                        <div class="row g-3">
                                            <div class="col-md-4">
                                                <label class="form-label">Quantity</label>
                                                <input type="number" name="quantity" value="1" min="1" max="@Math.Max(1, it.Quantity - it.DispensedQuantity)" class="form-control" />
                                            </div>
                                            <div class="col-md-8">
                                                <label class="form-label">Inventory source</label>
                                                <select name="inventoryItemId" class="form-select">
                                                    <option value="">Use linked item if available</option>
                                                    @foreach (var inventoryItem in inventoryItems)
                                                    {
                                                        if (inventoryItem.Id == it.InventoryItemId)
                                                        {
                                                            <option value="@inventoryItem.Id" selected="selected">@inventoryItem.Name (@inventoryItem.Code)</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@inventoryItem.Id">@inventoryItem.Name (@inventoryItem.Code)</option>
                                                        }
                                                    }
                                                </select>
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Dispensed medication name</label>
                                                <input name="dispensedMedicationName" class="form-control" placeholder="Only if dispensing a substitute" />
                                            </div>
                                            <div class="col-md-6">
                                                <label class="form-label">Credit reason</label>
                                                <input name="reason" class="form-control" placeholder="Optional if billing on credit" />
                                            </div>
                                            <div class="col-12">
                                                <label class="form-label">Dispense note</label>
                                                <textarea name="note" class="form-control" rows="3" placeholder="Partial dispense, external sourcing, or substitution note"></textarea>
                                            </div>
                                            <div class="col-12">
                                                <div class="form-check">
                                                    <input class="form-check-input" type="checkbox" value="true" name="allowOnCredit" id="credit_@it.Id">
                                                    <label class="form-check-label" for="credit_@it.Id">Allow billing on credit</label>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="card-footer bg-transparent border-0 pt-0">
                                        <button class="btn btn-primary">Dispense and Bill</button>
                                    </div>
                                </form>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
