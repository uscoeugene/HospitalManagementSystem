@model HMS.UI.Models.Reports.LabStatusBreakdownViewModel[]
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Lab - Status Breakdown";
}

<div class="container py-4">
    <h3>Lab Requests - Status Breakdown</h3>

    @if(TempData["Error"] != null)
    {
        <div class="alert alert-danger">@TempData["Error"]</div>
    }

    <table class="table table-striped">
        <thead><tr><th>Status</th><th class="text-end">Count</th></tr></thead>
        <tbody>
            @if(Model != null && Model.Length > 0)
            {
                foreach(var m in Model)
                {
                    <tr>
                        <td>@m.Status</td>
                        <td class="text-end">@m.Count</td>
                    </tr>
                }
            }
            else
            {
                <tr><td colspan="2" class="text-center text-muted">No data</td></tr>
            }
        </tbody>
    </table>
</div>
