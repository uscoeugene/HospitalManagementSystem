@model HMS.UI.Models.Auth.ResetPasswordViewModel
@{
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
    ViewData["Title"] = "Reset Password";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-7 col-lg-5">
            <div class="card shadow-sm border-0">
                <div class="card-body p-4">
                    <div class="text-center mb-4">
                        <i class="bi bi-key-fill text-primary" style="font-size:2.5rem;"></i>
                        <h3 class="mt-3 mb-1">Reset Password</h3>
                        <p class="text-muted mb-0">
                            @if (!string.IsNullOrWhiteSpace(Model.Username))
                            {
                                <span>Set a new password for <strong>@Model.Username</strong>.</span>
                            }
                            else
                            {
                                <span>Set a new password for your account.</span>
                            }
                        </p>
                    </div>

                    <partial name="_StatusAlerts" />
                    @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                    @if (!Model.IsValid)
                    {
                        <div class="alert alert-warning mb-0">
                            This recovery link is invalid or expired.
                        </div>
                    }
                    else
                    {
                        <form method="post">
                            @Html.AntiForgeryToken()
                            <input asp-for="Token" type="hidden" />
                            <div class="mb-3">
                                <label asp-for="NewPassword" class="form-label">New password</label>
                                <input asp-for="NewPassword" class="form-control" type="password" required minlength="8" />
                            </div>
                            <div class="mb-4">
                                <label asp-for="ConfirmPassword" class="form-label">Confirm password</label>
                                <input asp-for="ConfirmPassword" class="form-control" type="password" required minlength="8" />
                            </div>
                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary">
                                    <i class="bi bi-check2-circle me-1"></i>Reset password
                                </button>
                                <a asp-action="Login" class="btn btn-outline-secondary">Back to login</a>
                            </div>
                        </form>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
