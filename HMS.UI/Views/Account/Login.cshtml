@{
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>Login - HMS Cloud</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="/lib/toastr/toastr.min.css" rel="stylesheet" />
    <link href="~/css/hms-login.css" rel="stylesheet" />
</head>

<body>

    <div class="container login-wrapper d-flex align-items-center">
        <div class="row align-items-center w-100">

            <!-- LEFT SIDE -->
            <div class="col-lg-6 mb-5 mb-lg-0">

                <div class="brand-panel">

                    <div class="tenant-badge">
                        <i class="bi bi-diagram-3-fill"></i>
                        Multi-Tenant HMS Platform
                    </div>

                    <h1 class="brand-title mb-4">
                        <i class="bi bi-hospital-fill"></i>
                        HMS Cloud
                    </h1>

                    <p class="brand-subtitle mb-4">
                        A modern hospital management platform built for hospitals,
                        clinics, laboratories and healthcare networks with secure
                        tenant isolation and enterprise-grade scalability.
                    </p>

                    <div class="feature-pill">
                        <i class="bi bi-shield-check"></i>
                        Secure Tenant Isolation
                    </div>

                    <br />

                    <div class="feature-pill">
                        <i class="bi bi-heart-pulse-fill"></i>
                        Clinical & Patient Management
                    </div>

                    <br />

                    <div class="feature-pill">
                        <i class="bi bi-cash-stack"></i>
                        Billing & Revenue Automation
                    </div>

                    <div class="welcome-card">
                        <h5 class="mb-3">
                            Welcome Back
                        </h5>

                        <p>
                            Sign in to continue managing healthcare operations,
                            appointments, patients, pharmacy, laboratory and billing
                            activities across your organization.
                        </p>

                        @{
                            var tenantName = Context.Request.Cookies["HmsTenantName"] ?? string.Empty;
                            if (!string.IsNullOrWhiteSpace(tenantName))
                            {
                                <div class="mt-3 badge bg-light text-dark"> @tenantName</div>
                            }
                        }
                    </div>

                </div>

            </div>

            <!-- RIGHT SIDE -->
            <div class="col-lg-5 offset-lg-1">

                <div class="card login-card">

                    <div class="login-header">
                        <i class="bi bi-person-circle"></i>

                        <h3 class="mt-3 mb-1">
                            Sign In
                        </h3>

                        <p class="mb-0 opacity-75">
                            Access your HMS dashboard
                        </p>
                    </div>

                    <div class="login-body">

                        <form method="post"
                              asp-controller="Account"
                              asp-action="Login"
                              id="loginForm">

                            <input type="hidden" name="tenantCode" value="@(ViewData["TenantCode"] ?? string.Empty)" id="tenantCodeInput" />

                            @Html.AntiForgeryToken()

                            @Html.ValidationSummary(
                            true,
                                                        "",
                                                        new { @class = "alert alert-danger" }
                                                        )

                            <!-- USERNAME -->
                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Username
                                </label>

                                <div class="input-group-custom">

                                    <i class="bi bi-person-fill"></i>

                                    <input name="username"
                                           class="form-control"
                                           placeholder="Enter your username" />

                                </div>

                            </div>

                            <!-- PASSWORD -->
                            <div class="mb-4">

                                <label class="form-label fw-semibold">
                                    Password
                                </label>

                                <div class="input-group-custom">

                                    <i class="bi bi-lock-fill"></i>

                                    <input name="password"
                                           type="password"
                                           class="form-control"
                                           placeholder="Enter your password" />

                                </div>

                            </div>

                            <!-- REMEMBER -->
                            <div class="d-flex justify-content-between align-items-center mb-4">

                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           id="rememberMe" />

                                    <label class="form-check-label"
                                           for="rememberMe">
                                        Remember me
                                    </label>
                                </div>

                                <a href="#"
                                   class="text-decoration-none fw-semibold">
                                    Forgot password?
                                </a>

                            </div>

                            <!-- BUTTON -->
                            <button class="btn btn-primary btn-login w-100"
                                    type="submit">

                                <i class="bi bi-box-arrow-in-right"></i>
                                Sign In

                            </button>

                        </form>

                    </div>

                </div>

                <div class="text-center mt-4 footer-text">
                    © 2026 HMS Cloud — Smart Healthcare Management
                </div>

            </div>

        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/lib/toastr/toastr.min.js"></script>

    <script>
        document.getElementById('loginForm')
            .addEventListener('submit', function (e) {

                const u = this.querySelector('[name="username"]')
                    .value.trim();

                const p = this.querySelector('[name="password"]')
                    .value.trim();

                if (!u || !p) {

                    e.preventDefault();

                    toastr.error(
                        'Username and password are required'
                    );
                }
                // attach tenant code if present in URL path (/login/{code})
                try {
                    var parts = location.pathname.split('/');
                    if (parts.length > 2 && parts[1].toLowerCase() === 'login') {
                        var code = parts[2];
                        if (code) document.getElementById('tenantCodeInput').value = code;
                    }
                } catch (e) { }
            });
    </script>

</body>
</html>