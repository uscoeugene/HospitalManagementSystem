@{
    Layout = null;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Login - HMS Cloud</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="~/css/hms-login.css" rel="stylesheet" />
</head>
<body>
    <div class="container login-wrapper d-flex align-items-center">
        <div class="row align-items-center w-100">
            <div class="col-lg-6 mb-5 mb-lg-0">
                <div class="brand-panel">
                    <div class="tenant-badge">
                        <i class="bi bi-diagram-3-fill"></i>
                        Multi-Tenant HMS Platform
                    </div>
                    <h1 class="brand-title mb-4">
                        <i class="bi bi-hospital-fill"></i>
                        HMS Cloud
                    </h1>
                    <p class="brand-subtitle mb-4">
                        Secure, enterprise-grade hospital management for clinical operations, pharmacy,
                        laboratory workflows, billing, and tenant-isolated administration.
                    </p>
                    <div class="feature-pill"><i class="bi bi-shield-check"></i>Secure Tenant Isolation</div>
                    <br />
                    <div class="feature-pill"><i class="bi bi-people-fill"></i>Centralized Staff Administration</div>
                    <br />
                    <div class="feature-pill"><i class="bi bi-envelope-check"></i>Email-Based Account Recovery</div>
                </div>
            </div>

            <div class="col-lg-5 offset-lg-1">
                <div class="card login-card shadow border-0">
                    <div class="login-header">
                        <i class="bi bi-person-circle"></i>
                        <h3 class="mt-3 mb-1">Sign In</h3>
                        <p class="mb-0 opacity-75">Access your HMS dashboard</p>
                    </div>

                    <div class="login-body">
                        @if (TempData["Success"] != null)
                        {
                            <div class="alert alert-success">@TempData["Success"]</div>
                        }
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert alert-danger">@TempData["Error"]</div>
                        }

                        <form method="post" asp-controller="Account" asp-action="Login">
                            @Html.AntiForgeryToken()
                            @Html.ValidationSummary(true, "", new { @class = "alert alert-danger" })

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Username</label>
                                <div class="input-group-custom">
                                    <i class="bi bi-person-fill"></i>
                                    <input name="username" class="form-control" placeholder="Enter your username" required />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label class="form-label fw-semibold">Password</label>
                                <div class="input-group-custom">
                                    <i class="bi bi-lock-fill"></i>
                                    <input name="password" type="password" class="form-control" placeholder="Enter your password" required />
                                </div>
                            </div>

                            <div class="d-flex justify-content-end mb-4">
                                <a asp-action="ForgotPassword" class="text-decoration-none fw-semibold">Forgot password?</a>
                            </div>

                            <button class="btn btn-primary btn-login w-100" type="submit">
                                <i class="bi bi-box-arrow-in-right"></i>
                                Sign In
                            </button>
                        </form>
                    </div>
                </div>

                <div class="text-center mt-4 footer-text">
                    © 2026 HMS Cloud - Smart Healthcare Management
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
