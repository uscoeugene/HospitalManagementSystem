@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Billing Dashboard";
}

<div class="page-content">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="page-title">
                <i class="bi bi-speedometer2 me-2 text-primary"></i>
                Billing Dashboard
            </h1>
            <p class="text-muted mb-0">
                Financial overview, invoice activity, and payment analytics
            </p>
        </div>

        <div class="d-flex gap-2">
            <a href="/Billing/Invoices" class="btn btn-primary">
                <i class="bi bi-receipt me-1"></i> View Invoices
            </a>
        </div>

    </div>

    <!-- KPI ROW -->
    <div class="row g-3 mb-4">

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-primary shadow-soft">
                <h2>₦8.4M</h2>
                <p>Total Revenue</p>
                <i class="bi bi-cash-stack"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-success shadow-soft">
                <h2>124</h2>
                <p>Paid Invoices</p>
                <i class="bi bi-check2-circle"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-warning shadow-soft">
                <h2>38</h2>
                <p>Pending Payments</p>
                <i class="bi bi-clock-history"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-danger shadow-soft">
                <h2>₦1.2M</h2>
                <p>Outstanding Balance</p>
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
        </div>

    </div>

    <!-- SECOND ROW: QUICK INSIGHTS -->
    <div class="row g-4 mb-4">

        <div class="col-xl-8">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">

                    <h5 class="mb-3">
                        <i class="bi bi-graph-up me-1 text-success"></i>
                        Revenue Trend (Mock)
                    </h5>

                    <div class="bg-light rounded p-4 text-center text-muted">
                        <i class="bi bi-bar-chart-line fs-1"></i>
                        <div>Chart Area (Revenue over time)</div>
                    </div>

                </div>
            </div>
        </div>

        <div class="col-xl-4">

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted">Today</h6>
                    <h4>₦420,000</h4>
                    <small class="text-success">
                        <i class="bi bi-arrow-up"></i> +12% vs yesterday
                    </small>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted">This Week</h6>
                    <h4>₦2.9M</h4>
                    <small class="text-success">
                        <i class="bi bi-arrow-up"></i> +8% growth
                    </small>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Average Invoice</h6>
                    <h4>₦18,500</h4>
                    <small class="text-muted">Across all departments</small>
                </div>
            </div>

        </div>

    </div>

    <!-- RECENT ACTIVITY -->
    <div class="card border-0 shadow-sm">

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history me-1 text-primary"></i>
                    Recent Billing Activity
                </h5>
                <a href="/Billing/Invoices" class="btn btn-sm btn-outline-primary">
                    View All
                </a>
            </div>

            <div class="list-group list-group-flush">

                <div class="list-group-item d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold">Invoice #INV-1042</div>
                        <div class="text-muted small">John Doe - Lab Services</div>
                    </div>
                    <span class="badge bg-success">Paid</span>
                </div>

                <div class="list-group-item d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold">Invoice #INV-1043</div>
                        <div class="text-muted small">Mary James - Consultation</div>
                    </div>
                    <span class="badge bg-warning text-dark">Partial</span>
                </div>

                <div class="list-group-item d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold">Invoice #INV-1044</div>
                        <div class="text-muted small">Emergency Admission</div>
                    </div>
                    <span class="badge bg-secondary">Pending</span>
                </div>

            </div>

        </div>

    </div>

</div>