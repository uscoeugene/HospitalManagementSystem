@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Laboratory Dashboard";
}

<div class="page-content">

    <!-- HEADER -->
    <div class="d-flex flex-column flex-lg-row justify-content-between align-items-lg-center gap-3 mb-4">

        <div>
            <h1 class="page-title">
                <i class="bi bi-eyedropper me-2 text-primary"></i>
                Laboratory Dashboard
            </h1>
            <p class="text-muted mb-0">
                Test processing, sample tracking, and result workflows
            </p>
        </div>

        <div class="d-flex gap-2">
            <a href="/Lab/Requests" class="btn btn-primary">
                <i class="bi bi-clipboard-data me-1"></i> Lab Requests
            </a>
            <a href="/Lab/Tests" class="btn btn-outline-primary">
                <i class="bi bi-list-check me-1"></i> Lab Tests
            </a>
          
        </div>

    </div>

    <!-- KPI CARDS -->
    <div class="row g-3 mb-4">

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-primary shadow-soft">
                <h2>86</h2>
                <p>Total Lab Tests</p>
                <i class="bi bi-activity"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-warning shadow-soft">
                <h2>34</h2>
                <p>Pending Samples</p>
                <i class="bi bi-hourglass-split"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-success shadow-soft">
                <h2>120</h2>
                <p>Completed Tests</p>
                <i class="bi bi-check2-circle"></i>
            </div>
        </div>

        <div class="col-md-6 col-xl-3">
            <div class="stats-card bg-gradient-danger shadow-soft">
                <h2>12</h2>
                <p>Critical Results</p>
                <i class="bi bi-exclamation-triangle-fill"></i>
            </div>
        </div>

    </div>

    <!-- WORKFLOW OVERVIEW -->
    <div class="row g-4 mb-4">

        <!-- LEFT: PROCESS FLOW -->
        <div class="col-xl-8">

            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">

                    <h5 class="mb-3">
                        <i class="bi bi-diagram-3 me-1 text-success"></i>
                        Lab Workflow Status
                    </h5>

                    <div class="row g-3">

                        <div class="col-md-4">
                            <div class="card bg-light border-0">
                                <div class="card-body">
                                    <div class="text-muted small">Collected</div>
                                    <h4>42</h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card bg-light border-0">
                                <div class="card-body">
                                    <div class="text-muted small">Processing</div>
                                    <h4>28</h4>
                                </div>
                            </div>
                        </div>

                        <div class="col-md-4">
                            <div class="card bg-light border-0">
                                <div class="card-body">
                                    <div class="text-muted small">Ready</div>
                                    <h4>18</h4>
                                </div>
                            </div>
                        </div>

                    </div>

                    <div class="bg-light rounded p-4 text-center text-muted mt-3">
                        <i class="bi bi-graph-up fs-1"></i>
                        <div>Sample processing trend chart area</div>
                    </div>

                </div>
            </div>

        </div>

        <!-- RIGHT: QUICK INSIGHTS -->
        <div class="col-xl-4">

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted">Today's Tests</h6>
                    <h4>64</h4>
                    <small class="text-success">
                        <i class="bi bi-arrow-up"></i> +10% increase
                    </small>
                </div>
            </div>

            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    <h6 class="text-muted">Turnaround Time</h6>
                    <h4>4.2 hrs</h4>
                    <small class="text-muted">Average processing time</small>
                </div>
            </div>

            <div class="card border-0 shadow-sm">
                <div class="card-body">
                    <h6 class="text-muted">Critical Alerts</h6>
                    <h4 class="text-danger">12</h4>
                    <small class="text-danger">
                        <i class="bi bi-exclamation-triangle"></i> Needs attention
                    </small>
                </div>
            </div>

        </div>

    </div>

    <!-- RECENT ACTIVITY -->
    <div class="card border-0 shadow-sm">

        <div class="card-body">

            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5 class="mb-0">
                    <i class="bi bi-clock-history me-1 text-primary"></i>
                    Recent Lab Activity
                </h5>
                <a href="/Lab/Requests" class="btn btn-sm btn-outline-primary">
                    View All
                </a>
            </div>

            <div class="list-group list-group-flush">

                <div class="list-group-item d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold">CBC Test Completed</div>
                        <div class="text-muted small">Patient: John Doe</div>
                    </div>
                    <span class="badge bg-success">Completed</span>
                </div>

                <div class="list-group-item d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold">Malaria Test Pending</div>
                        <div class="text-muted small">Sample received</div>
                    </div>
                    <span class="badge bg-warning text-dark">Processing</span>
                </div>

                <div class="list-group-item d-flex justify-content-between">
                    <div>
                        <div class="fw-semibold">Electrolyte Panel</div>
                        <div class="text-muted small">Critical result flagged</div>
                    </div>
                    <span class="badge bg-danger">Critical</span>
                </div>

            </div>

        </div>

    </div>

</div>