@model HMS.UI.Models.Lab.LabTestViewModel[]
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Lab Tests";
}

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4">
        <div>
            <h3 class="mb-0">
                <i class="bi bi-clipboard2-pulse me-2 text-primary"></i>
                Lab Tests
            </h3>
            <small class="text-muted">Manage all laboratory tests</small>
        </div>

        <a class="btn btn-success-custom" asp-action="requests" asp-controller="Lab">
            <i class="bi bi-plus-circle me-1"></i>
            Lab Requests
        </a>
        @if (User.Identity?.IsAuthenticated ?? false && User.HasClaim("perm", "lab.manage"))
        {
            <a class="btn btn-primary" asp-action="create" asp-controller="Lab">
                <i class="bi bi-plus-circle me-1"></i>
                Create Test
            </a>
        }
    </div>

    <!-- Alerts -->
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show">
            <i class="bi bi-exclamation-triangle me-1"></i>
            @TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show">
            <i class="bi bi-check-circle me-1"></i>
            @TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <!-- Card Wrapper -->
    <div class="card shadow-sm border-0">
        <div class="card-body p-0">

            <!-- Table -->
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">

                    <thead class="table-light">
                        <tr>
                            <th>
                                <i class="bi bi-upc-scan me-1"></i> Code
                            </th>
                            <th>
                                <i class="bi bi-flask me-1"></i> Name
                            </th>
                            <th>
                                <i class="bi bi-cash-coin me-1"></i> Price
                            </th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (Model != null && Model.Length > 0)
                        {
                            foreach (var t in Model)
                            {
                                <tr>
                                    <td>
                                        <span class="badge bg-light text-dark border">
                                            @t.Code
                                        </span>
                                    </td>

                                    <td class="fw-semibold">
                                        @t.Name
                                    </td>

                                    <td>
                                        <span class="text-success fw-semibold">
                                            @t.Price @t.Currency
                                        </span>
                                    </td>

                                    <td class="text-end">
                                        <a class="btn btn-sm btn-outline-primary"
                                           href="/Lab/Details?id=@t.Id">
                                            <i class="bi bi-eye me-1"></i>
                                            Details
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center py-5 text-muted">
                                    <i class="bi bi-inbox display-6 d-block mb-2"></i>
                                    No lab tests found
                                </td>
                            </tr>
                        }
                    </tbody>

                </table>
            </div>

        </div>
    </div>
</div>