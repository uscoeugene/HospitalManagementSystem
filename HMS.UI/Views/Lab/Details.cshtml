@model HMS.UI.Models.Lab.LabRequestViewModel
@{
    Layout = "~/Pages/_Layout.cshtml";
    ViewData["Title"] = "Lab Request Details";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-body">
            <h5 class="mb-2">Lab Request: @Model.Id</h5>
            <div class="mb-2">Date: <strong>@(Model.CreatedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-")</strong></div>
            <div class="mb-2">Patient: <strong>@(Model.PatientName ?? "-")</strong></div>
            <div class="mb-3">Status: <strong>@Model.Status</strong> • Invoice: <strong>@(Model.InvoiceStatus ?? "-")</strong> • Items: <strong>@Model.ItemsCount</strong></div>

            @if(!string.IsNullOrWhiteSpace(Model.InvoiceStatus) && !Model.InvoiceStatus.Equals("PAID", StringComparison.OrdinalIgnoreCase) && !Model.InvoiceStatus.Equals("CHARGED", StringComparison.OrdinalIgnoreCase))
            {
                <div class="alert alert-warning">This lab request invoice has not been paid. Results may not be updated unless charged on credit.</div>
            }

            <h6>Items</h6>
            <div class="list-group mb-3">
                @foreach(var it in Model.Items)
                {
                    <div class="list-group-item">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <div class="fw-semibold">@it.LabTest?.Name ?? it.LabTestId.ToString()</div>
                                <div class="small text-muted">Code: @it.LabTest?.Code</div>
                                <div class="small text-muted">Price: @it.Price @it.Currency</div>
                            </div>
                            <div class="text-end">
                                <div class="small text-muted">Status: @it.ResultStatus</div>
                                <a class="btn btn-sm btn-outline-primary" data-bs-toggle="collapse" href="#res_@it.Id" role="button" aria-expanded="false" aria-controls="res_@it.Id">View / Update</a>
                            </div>
                        </div>

                        <div class="collapse mt-3" id="res_@it.Id">
                            <div class="card card-body">
                                <form method="post" asp-action="UpdateResult" asp-controller="Lab">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="requestId" value="@Model.Id" />
                                    <input type="hidden" name="itemId" value="@it.Id" />

                                    <div class="mb-2">
                                        <label class="form-label">Result Value</label>
                                        <input name="ResultValue" class="form-control" value="@it.ResultValue" />
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label">Unit</label>
                                        <input name="ResultUnit" class="form-control" value="@it.ResultUnit" />
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label">Reference Range</label>
                                        <input name="ReferenceRange" class="form-control" value="@it.ReferenceRange" />
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label">Abnormal Flag</label>
                                        <input name="AbnormalFlag" class="form-control" value="@it.AbnormalFlag" />
                                    </div>

                                    <div class="mb-2">
                                        <label class="form-label">Notes</label>
                                        <textarea name="ResultNotes" class="form-control">@it.ResultNotes</textarea>
                                    </div>

                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="checkbox" name="Verify" value="true" id="verify_@it.Id" />
                                        <label class="form-check-label" for="verify_@it.Id">Verify result</label>
                                    </div>

                                    <div class="d-flex justify-content-end gap-2">
                                        <button class="btn btn-secondary" type="button" data-bs-toggle="collapse" data-bs-target="#res_@it.Id">Close</button>
                                        <button class="btn btn-primary">Save</button>
                                    </div>
                                </form>

                                <div class="mt-3">
                                    <form method="post" asp-action="UploadResultAttachment" asp-controller="Lab" enctype="multipart/form-data">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="requestId" value="@Model.Id" />
                                        <input type="hidden" name="itemId" value="@it.Id" />
                                        <div class="input-group">
                                            <input type="file" name="file" class="form-control" />
                                            <button class="btn btn-outline-secondary">Upload</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>

                    </div>
                }
            </div>

            <a asp-action="Requests" class="btn btn-light">Back to requests</a>
        </div>
    </div>
</div>
