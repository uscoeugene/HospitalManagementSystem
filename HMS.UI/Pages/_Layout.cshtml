@inherits Microsoft.AspNetCore.Mvc.Razor.RazorPage<dynamic>
@using System.Security.Claims
@{
    var currentPath = Context.Request.Path.Value ?? string.Empty;
    var displayName = User.FindFirst("display_name")?.Value
        ?? User.Identity?.Name
        ?? "User";
    if (string.IsNullOrWhiteSpace(displayName))
    {
        displayName = "User";
    }
    var userInitial = displayName.Substring(0, 1).ToUpperInvariant();
    var tenantName = User.FindFirst("tenant_name")?.Value
        ?? ViewData["TenantName"] as string
        ?? Context.Request.Cookies["HmsTenantName"]
        ?? string.Empty;
}

<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - HMS Cloud</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    @* <link href="/lib/toastr/toastr.min.css" rel="stylesheet" /> *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.css">

    <link href="/css/hms-portal.css" rel="stylesheet" />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css"
          rel="stylesheet" />
</head>

<body class="portal-layout">

    <!-- SIDEBAR -->
    <aside class="sidebar" id="portalSidebar">

        <!-- BRAND -->
        <div class="sidebar-brand">
            <div class="d-flex align-items-start justify-content-between gap-3">
                <div class="d-flex align-items-center gap-3">

                    <div class="brand-logo">
                        <i class="bi bi-hospital-fill"></i>
                    </div>

                    <div>
                        <h3>HMS Cloud</h3>
                        <p>@(!string.IsNullOrWhiteSpace(tenantName) ? tenantName : "Hospital Management")</p>
                    </div>
                </div>

                <button type="button" class="btn btn-outline-light btn-sm d-lg-none sidebar-close-button" data-sidebar-close aria-label="Close menu">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>
        </div>

        <!-- MENU -->
        <div class="sidebar-menu">

            <div class="sidebar-menu-title">
                Main Menu
            </div>

            <a class="sidebar-link @(currentPath.StartsWith("/Account/Dashboard", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Account/Dashboard">
                <i class="bi bi-grid-1x2-fill"></i>
                <span>Dashboard</span>
            </a>

            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a class="sidebar-link @(currentPath.StartsWith("/Patients", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Patients">
                    <i class="bi bi-people-fill"></i>
                    <span>Patients</span>
                </a>

                <a class="sidebar-link @(currentPath.StartsWith("/Lab", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Lab">
                    <i class="bi bi-heart-pulse-fill"></i>
                    <span>Laboratory</span>
                </a>

                <a class="sidebar-link @(currentPath.StartsWith("/Pharmacy", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Pharmacy">
                    <i class="bi bi-capsule-pill"></i>
                    <span>Pharmacy</span>
                </a>

                <a class="sidebar-link @(currentPath.StartsWith("/Billing", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Billing">
                    <i class="bi bi-cash-stack"></i>
                    <span>Billing</span>
                </a>

                <a class="sidebar-link @(currentPath.StartsWith("/Reports", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Reports">
                    <i class="bi bi-bar-chart-fill"></i>
                    <span>Reports</span>
                </a>
            }

            <div class="sidebar-menu-title mt-4">
                Administration
            </div>

            <a class="sidebar-link @(currentPath.StartsWith("/Profile/Me", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Profile/Me">
                <i class="bi bi-person-circle"></i>
                <span>My Profile</span>
            </a>

            @if (User.HasClaim("permission", "PROFILE.UPDATE"))
            {
                <a class="sidebar-link @(currentPath.StartsWith("/Profile/Security", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Profile/Security">
                    <i class="bi bi-shield-lock-fill"></i>
                    <span>Security</span>
                </a>
            }

            @if (User.Identity?.IsAuthenticated ?? false)
            {
                <a class="sidebar-link @(currentPath.StartsWith("/Users", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Users">
                    <i class="bi bi-people-fill"></i>
                    <span>Users</span>
                </a>

                <a class="sidebar-link @(currentPath.StartsWith("/Roles", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Roles">
                    <i class="bi bi-person-gear"></i>
                    <span>Roles & Permissions</span>
                </a>

                <a class="sidebar-link @(currentPath.StartsWith("/Admin/LocalTenant", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Admin/LocalTenant">
                    <i class="bi bi-building-gear"></i>
                    <span>Local Tenant</span>
                </a>

                <a class="sidebar-link @(currentPath.StartsWith("/Admin/AppSettings", StringComparison.OrdinalIgnoreCase) ? "active" : string.Empty)" href="/Admin/AppSettings">
                    <i class="bi bi-sliders"></i>
                    <span>App Settings</span>
                </a>
            }

            <!-- LOGOUT -->
            <form method="post"
                  action="/Account/Logout"
                  class="mt-3 px-3">

                @Html.AntiForgeryToken()

                <button class="btn btn-danger w-100 rounded-pill py-2">
                    <i class="bi bi-box-arrow-right me-2"></i>
                    Logout
                </button>
            </form>

        </div>

    </aside>
    <div class="sidebar-backdrop d-lg-none" data-sidebar-close></div>

    <!-- MAIN -->
    <div class="main-content">

        <!-- TOPBAR -->
        <header class="topbar">

            <div class="topbar-content">

                <!-- LEFT -->
                <div class="d-flex align-items-center gap-3">

                    <button type="button" class="btn btn-light rounded-circle shadow-sm d-lg-none"
                            data-sidebar-toggle
                            aria-label="Open menu">
                        <i class="bi bi-list"></i>
                    </button>

                    <div>
                        <h4 class="mb-0 fw-bold">
                            @ViewData["Title"]
                        </h4>

                        <small class="text-muted">
                            HMS Management Portal
                        </small>
                    </div>

                </div>

                <!-- RIGHT -->
                <div class="d-flex align-items-center gap-3">

                    <div class="topbar-user">

                        <div class="avatar-sm">
                            @userInitial
                        </div>

                        <div class="d-none d-md-block">
                            <div class="fw-semibold">
                                @displayName
                            </div>

                    <small class="text-muted">
                        Signed in
                        @if (!string.IsNullOrWhiteSpace(tenantName))
                        {
                            <text> | @tenantName</text>
                        }
                    </small>
                        </div>

                    </div>

                </div>

            </div>

        </header>

      
        <!-- CONTENT -->
        <main class="page-content">
            <div class="">
                @RenderBody()
            </div>
        </main>

    </div>
    @* <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery/3.7.1/jquery.min.js"></script> *@
    <!-- jQuery -->
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/portal-layout.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/toastr.min.js" ></script>

    <script>
    
        toastr.options = {
            closeButton: true,
            progressBar: true,
            positionClass: "toast-top-right",
            timeOut: "3000"
        };
    
        // Show server-side TempData messages using toastr
        document.addEventListener('DOMContentLoaded', function () {
            try {
                // TempData keys: Success, Error, Info
                       @if (TempData["Success"] != null)
        {
                <text>
                    toastr.success(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Success"])));
                </text>
        }

        @if (TempData["Error"] != null)
        {
                <text>
                    toastr.error(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Error"])));
                </text>
        }

        @if (TempData["Info"] != null)
        {
                <text>
                    toastr.info(@Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["Info"])));
                </text>
        }

                // Also convert any inline alert elements into toastr notifications
                // document.querySelectorAll('.page-content .alert').forEach(function (el) {
                //     var text = el.innerText.trim();
                //     if (!text) return;
                //     if (el.classList.contains('alert-success')) toastr.success(text);
                //     else if (el.classList.contains('alert-danger') || el.classList.contains('alert-warning')) toastr.error(text);
                //     else toastr.info(text);
                //     el.remove();
                // });
            } catch (e) {
                // ignore
            }
        });

    // Show client-side toasts for deployment/tenant name resolution issues
    document.addEventListener('DOMContentLoaded', function () {
        try {
            var tResolve = (document.cookie.match(/(?:^|; )HmsTenantNameResolveFailed=([^;]+)/) || [])[1];
            if (tResolve === '1') {
                toastr.warning('Tenant name could not be resolved automatically. Some tenant-specific features may be limited.');
                // clear cookie
                document.cookie = 'HmsTenantNameResolveFailed=;path=/;max-age=0';
            }

            var dmUnknown = (document.cookie.match(/(?:^|; )HmsDeploymentModeUnknown=([^;]+)/) || [])[1];
            if (dmUnknown === '1') {
                toastr.info('Deployment mode could not be determined; some UI indicators may show "Unknown".');
                document.cookie = 'HmsDeploymentModeUnknown=;path=/;max-age=0';
            }
        } catch (e) { }
    });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
