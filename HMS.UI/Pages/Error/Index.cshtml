@page "{code:int}"
@model HMS.UI.Pages.Error.IndexModel

@{
    Layout = User.Identity != null && User.Identity.IsAuthenticated
        ? "_Layout"
        : "_AuthLayout";
}

@{
    ViewData["Title"] = "Error";

    var statusCode = Model.StatusCode;

    var icon = statusCode switch
    {
        404 => "bi-search",
        403 => "bi-shield-lock",
        500 => "bi-exclamation-octagon",
        _ => "bi-exclamation-circle"
    };

    var title = statusCode switch
    {
        404 => "Page Not Found",
        403 => "Access Denied",
        500 => "Server Error",
        _ => "Something Went Wrong"
    };
}

<div class="error-page">

    <div class="error-card">

        <!-- ICON -->
        <div class="error-icon">
            <i class="bi @icon"></i>
        </div>

        <!-- STATUS -->
        <div class="error-code">
            @statusCode
        </div>

        <!-- TITLE -->
        <h1 class="error-title">
            @title
        </h1>

        <!-- MESSAGE -->
        <p class="error-message">
            @Model.Message
        </p>

        <!-- ACTIONS -->
        <div class="d-flex justify-content-center gap-3 flex-wrap">

            <a href="@(User.Identity != null && User.Identity.IsAuthenticated
                           ? Url.Action("Dashboard", "Account")
                           : Url.Page("/Index"))"
               class="btn btn-primary px-4 rounded-pill">

                <i class="bi bi-house-door me-2"></i>
                @(User.Identity != null && User.Identity.IsAuthenticated ? "Dashboard" : "Home")
            </a>

            <button class="btn btn-light border px-4 rounded-pill"
                    onclick="history.back()">

                <i class="bi bi-arrow-left me-2"></i>
                Go Back
            </button>

        </div>

    </div>

</div>